                <!-- hazard strip -->
                <GeometryDrawing Brush="#C79A2C" Geometry="M0,86 H215 V110 H0 Z M696,86 H1000 V110 H696 Z"/>
                <GeometryDrawing Brush="#171511" Geometry="M-5,110 L20,86 H48 L23,110 Z M50,110 L75,86 H103 L78,110 Z M105,110 L130,86 H158 L133,110 Z M160,110 L185,86 H213 L188,110 Z M691,110 L716,86 H744 L719,110 Z M746,110 L771,86 H799 L774,110 Z M801,110 L826,86 H854 L829,110 Z M856,110 L881,86 H909 L884,110 Z M911,110 L936,86 H964 L939,110 Z M966,110 L991,86 H1019 L994,110 Z"/>
