    </DrawingBrush>

    <DrawingBrush x:Key="StalkerApprovedInnerArtwork" TileMode="Tile" Viewport="0,0,440,320" ViewportUnits="Absolute" Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#080A07" Geometry="M0,0 H440 V320 H0 Z"/>
                <GeometryDrawing Brush="#18130D" Geometry="M0,0 H440 V7 H0 Z M0,313 H440 V320 H0 Z"/>
                <GeometryDrawing Brush="#2C190F" Geometry="M27,31 C58,14 96,20 112,43 C91,66 51,62 27,31 Z M301,210 C333,189 384,200 416,238 C382,269 336,260 301,210 Z"/>
                <GeometryDrawing Geometry="M17,72 L162,67 M97,131 L327,123 M23,246 L197,238 M252,54 L421,49" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#41685E4D" Thickness="0.9"/></GeometryDrawing.Pen></GeometryDrawing>
                <GeometryDrawing Geometry="M54,13 L59,164 M214,25 L208,184 M365,93 L359,303" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#43000000" Thickness="1.5"/></GeometryDrawing.Pen></GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style x:Key="StalkerWindowHeaderPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerApprovedHeaderArtwork}"/>
        <Setter Property="BorderBrush" Value="#865026"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource StalkerExactPanelShadow}"/>
    </Style>

    <Style x:Key="StalkerHudPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="#E1DCCB"/>
        <Setter Property="Background" Value="{StaticResource StalkerApprovedPanelArtwork}"/>
        <Setter Property="Padding" Value="18,14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid ClipToBounds="True">
                        <Border Margin="5,6,0,0" Background="#A8000000"/>
                        <Border x:Name="Outer" Background="{TemplateBinding Background}" BorderBrush="#80502A" BorderThickness="2.5"/>
                        <Border Margin="3" BorderBrush="#4C402D" BorderThickness="1"/>
                        <Rectangle Height="8" Margin="6" VerticalAlignment="Top" Fill="{StaticResource StalkerHazardBrush}" Opacity="0.62"/>
                        <Path Data="M0,28 L0,7 L7,0 L80,0" Stroke="#C68B31" StrokeThickness="2.2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        <Path Data="M80,28 L80,7 L73,0 L0,0" Stroke="#655A3C" StrokeThickness="2.2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Outer" Property="BorderBrush" Value="#AE7230"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerInnerBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerApprovedInnerArtwork}"/>
        <Setter Property="BorderBrush" Value="#65452A"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="1"/>
    </Style>

    <Style x:Key="StalkerListBox" TargetType="ListBox">
        <Setter Property="Foreground" Value="#E1DCCB"/>
        <Setter Property="Background" Value="{StaticResource StalkerApprovedInnerArtwork}"/>
        <Setter Property="BorderBrush" Value="#65452A"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>
</ResourceDictionary>