                <GeometryDrawing Geometry="M70,15 L124,82 H16 Z" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#D8A43D" Thickness="4"/></GeometryDrawing.Pen></GeometryDrawing>
                <GeometryDrawing Brush="#8BD64A" Geometry="M70,35 A9,9 0 1 0 70,53 A9,9 0 1 0 70,35 M68,31 C48,28 39,42 42,56 L58,50 C56,43 60,38 68,37 Z M74,31 C94,28 103,42 100,56 L84,50 C86,43 82,38 74,37 Z M70,57 C55,66 56,81 69,87 L73,70 C68,67 67,62 70,57 Z"/>
