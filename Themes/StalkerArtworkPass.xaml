                <GeometryDrawing Brush="#161710" Geometry="M289,24 H337 V56 H289 Z"/>
                <GeometryDrawing Brush="#83D44B" Geometry="M313,30 A6,6 0 1 0 313,42 A6,6 0 1 0 313,30 M311,27 C299,25 293,34 295,43 L305,39 C304,35 307,31 311,31 Z M315,27 C327,25 333,34 331,43 L321,39 C322,35 319,31 315,31 Z"/>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <DrawingBrush x:Key="StalkerApprovedInnerArtwork" TileMode="Tile" Viewport="0,0,220,160" ViewportUnits="Absolute" Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#0A0B08" Geometry="M0,0 H220 V160 H0 Z"/>
                <GeometryDrawing Brush="#24170F" Geometry="M0,0 H220 V8 H0 Z M0,152 H220 V160 H0 Z"/>
                <GeometryDrawing Brush="#432012" Geometry="M17,18 C48,4 80,14 90,34 C72,56 36,52 17,18 Z M128,103 C154,82 198,93 216,127 C187,156 150,145 128,103 Z"/>
                <GeometryDrawing Geometry="M9,55 L112,51 M66,86 L207,80 M13,130 L126,125" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#53796D54" Thickness="1"/></GeometryDrawing.Pen></GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Override the former colour-only styles with full illustrated artwork. -->
    <Style x:Key="StalkerWindowHeaderPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerApprovedHeaderArtwork}"/>
        <Setter Property="BorderBrush" Value="#9C5B2A"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource StalkerExactPanelShadow}"/>
    </Style>

    <Style x:Key="StalkerHudPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="#E1DCCB"/>
        <Setter Property="Background" Value="{StaticResource StalkerApprovedPanelArtwork}"/>
        <Setter Property="Padding" Value="18,14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid ClipToBounds="True">
                        <Border Margin="6,7,0,0" Background="#C0000000"/>
                        <Border x:Name="Outer" Background="{TemplateBinding Background}" BorderBrush="#9A5B2A" BorderThickness="3"/>
                        <Border Margin="4" BorderBrush="#59462E" BorderThickness="1"/>
                        <Rectangle Height="10" Margin="7" VerticalAlignment="Top" Fill="{StaticResource StalkerHazardBrush}" Opacity="0.78"/>
                        <Path Data="M0,32 L0,8 L8,0 L92,0" Stroke="#D99D3A" StrokeThickness="3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        <Path Data="M92,32 L92,8 L84,0 L0,0" Stroke="#7C6C43" StrokeThickness="3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Outer" Property="BorderBrush" Value="#C78332"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerInnerBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerApprovedInnerArtwork}"/>
        <Setter Property="BorderBrush" Value="#7B542E"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="1"/>
    </Style>

    <Style x:Key="StalkerListBox" TargetType="ListBox">
        <Setter Property="Foreground" Value="#E1DCCB"/>
        <Setter Property="Background" Value="{StaticResource StalkerApprovedInnerArtwork}"/>
        <Setter Property="BorderBrush" Value="#7B542E"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>
</ResourceDictionary>