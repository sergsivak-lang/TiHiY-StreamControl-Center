                <!-- rivets -->
                <GeometryDrawing Brush="#9B8A69" Geometry="M10,10 A4,4 0 1 0 18,10 A4,4 0 1 0 10,10 M982,10 A4,4 0 1 0 990,10 A4,4 0 1 0 982,10 M10,92 A4,4 0 1 0 18,92 A4,4 0 1 0 10,92 M982,92 A4,4 0 1 0 990,92 A4,4 0 1 0 982,92"/>
