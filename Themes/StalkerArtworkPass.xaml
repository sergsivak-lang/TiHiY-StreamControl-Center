            <DrawingGroup>
                <GeometryDrawing Brush="#0D0F0B" Geometry="M0,0 H720 V460 H0 Z"/>
                <GeometryDrawing Brush="#221910" Geometry="M0,0 H720 V13 H0 Z M0,447 H720 V460 H0 Z"/>
                <GeometryDrawing Brush="#342014" Geometry="M34,47 C72,26 131,32 151,65 C123,95 66,91 34,47 Z M486,296 C534,264 610,278 649,330 C610,380 535,365 486,296 Z M275,164 C302,145 338,152 352,177 C334,202 295,199 275,164 Z"/>
