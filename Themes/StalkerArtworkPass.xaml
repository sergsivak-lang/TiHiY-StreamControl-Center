    <DrawingBrush x:Key="StalkerApprovedPanelArtwork" TileMode="Tile" Viewport="0,0,360,230" ViewportUnits="Absolute" Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#10110C" Geometry="M0,0 H360 V230 H0 Z"/>
                <GeometryDrawing Brush="#321D12" Geometry="M0,0 H360 V18 H0 Z M0,212 H360 V230 H0 Z"/>
                <GeometryDrawing Brush="#5D2C14" Geometry="M15,24 C58,6 108,15 125,46 C97,78 42,68 15,24 Z M223,146 C270,119 335,137 357,183 C321,224 257,211 223,146 Z"/>
                <GeometryDrawing Geometry="M12,64 L151,58 M75,102 L294,96 M18,177 L186,170 M234,43 L347,37" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#6C8B7B60" Thickness="1.2"/></GeometryDrawing.Pen></GeometryDrawing>
                <GeometryDrawing Geometry="M38,16 L45,116 M191,21 L185,112 M310,75 L302,210" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#62000000" Thickness="2.4"/></GeometryDrawing.Pen></GeometryDrawing>
                <GeometryDrawing Brush="#A78A6A47" Geometry="M10,10 A5,5 0 1 0 20,10 A5,5 0 1 0 10,10 M340,10 A5,5 0 1 0 350,10 A5,5 0 1 0 340,10 M10,210 A5,5 0 1 0 20,210 A5,5 0 1 0 10,210 M340,210 A5,5 0 1 0 350,210 A5,5 0 1 0 340,210"/>
