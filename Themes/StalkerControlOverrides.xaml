<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Deliberately no implicit Window style here. MainWindow owns the approved frame. -->

    <Style x:Key="PanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        <Setter Property="BorderBrush" Value="#8B7540"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect" Value="{DynamicResource SoftShadow}"/>
    </Style>

    <Style x:Key="CyberInnerBorder" TargetType="Border">
        <Setter Property="Background" Value="#F0080A06"/>
        <Setter Property="BorderBrush" Value="#665A36"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="StatusChip" TargetType="Border">
        <Setter Property="Background" Value="#F015170F"/>
        <Setter Property="BorderBrush" Value="#79683A"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="Padding" Value="11,7"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="Background" Value="#F20B0D08"/>
        <Setter Property="BorderBrush" Value="#75663C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="HudPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="#E2DEC9"/>
        <Setter Property="Background" Value="{DynamicResource PanelGradient}"/>
        <Setter Property="BorderBrush" Value="#887540"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid SnapsToDevicePixels="True">
                        <Border Margin="4,5,0,0" Background="#B0000000"/>
                        <Border Background="{TemplateBinding Background}" BorderBrush="#302D20" BorderThickness="6" CornerRadius="1"/>
                        <Border Margin="4" Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="2" CornerRadius="1"/>
                        <Border Margin="8" Background="#B5070905" BorderBrush="#413C28" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter Margin="1"/>
                                <Ellipse Width="6" Height="6" Fill="#17170F" Stroke="#9A8550" StrokeThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,-6,0,0"/>
                                <Ellipse Width="6" Height="6" Fill="#17170F" Stroke="#9A8550" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0"/>
                                <Ellipse Width="6" Height="6" Fill="#17170F" Stroke="#9A8550" StrokeThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-6,0,0,-6"/>
                                <Ellipse Width="6" Height="6" Fill="#17170F" Stroke="#9A8550" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-6,-6"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="#E7E0C8"/>
        <Setter Property="Background" Value="{DynamicResource BlueButtonBackground}"/>
        <Setter Property="BorderBrush" Value="#8C7640"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True">
                        <Border Margin="3,4,0,0" Background="#B0000000"/>
                        <Border x:Name="Outer" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                        <Border Margin="5" BorderBrush="#675B36" BorderThickness="1"/>
                        <Rectangle Height="2" Fill="#A0C69535" VerticalAlignment="Top" Margin="11,3,11,0"/>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Outer" Property="BorderBrush" Value="#D49A2E"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Outer" Property="Margin" Value="2,3,0,0"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Outer" Property="Opacity" Value="0.38"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="MinHeight" Value="40"/><Setter Property="BorderBrush" Value="#9A8244"/><Setter Property="HorizontalAlignment" Value="Stretch"/></Style>
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource RedButtonBackground}"/><Setter Property="BorderBrush" Value="#A14C38"/></Style>
    <Style x:Key="WindowButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Width" Value="34"/><Setter Property="Height" Value="28"/><Setter Property="MinWidth" Value="34"/><Setter Property="MinHeight" Value="28"/><Setter Property="Padding" Value="0"/></Style>
    <Style x:Key="ModuleAmberButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Width" Value="140"/><Setter Property="Height" Value="40"/><Setter Property="Background" Value="{DynamicResource AmberButtonBackground}"/><Setter Property="BorderBrush" Value="#BE8425"/><Setter Property="FontSize" Value="9.6"/></Style>
    <Style x:Key="AmberButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource AmberButtonBackground}"/><Setter Property="BorderBrush" Value="#C78B26"/></Style>
    <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="BorderBrush" Value="#768650"/></Style>
    <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource RedButtonBackground}"/><Setter Property="BorderBrush" Value="#A9533A"/></Style>
    <Style x:Key="PurpleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource PurpleButtonBackground}"/><Setter Property="BorderBrush" Value="#7A6A52"/></Style>
    <Style x:Key="TitleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Width" Value="42"/><Setter Property="Height" Value="34"/><Setter Property="MinHeight" Value="0"/><Setter Property="Padding" Value="0"/></Style>
    <Style x:Key="CloseTitleButton" TargetType="Button" BasedOn="{StaticResource TitleButton}"><Setter Property="Background" Value="{DynamicResource RedButtonBackground}"/><Setter Property="BorderBrush" Value="#A04B37"/></Style>
    <Style x:Key="ModuleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource ModuleBackground}"/><Setter Property="BorderBrush" Value="#796B42"/><Setter Property="Padding" Value="10,7"/><Setter Property="Margin" Value="5"/><Setter Property="MinHeight" Value="54"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="VerticalContentAlignment" Value="Stretch"/><Setter Property="FontSize" Value="11"/></Style>
    <Style x:Key="AmberModuleButton" TargetType="Button" BasedOn="{StaticResource ModuleButton}"><Setter Property="Background" Value="{DynamicResource AmberButtonBackground}"/><Setter Property="BorderBrush" Value="#B97B22"/></Style>

    <Style TargetType="TextBox"><Setter Property="Foreground" Value="#D8DFC1"/><Setter Property="Background" Value="#F0080A06"/><Setter Property="BorderBrush" Value="#71623B"/><Setter Property="BorderThickness" Value="2"/><Setter Property="CaretBrush" Value="#B9D36D"/><Setter Property="Padding" Value="9,7"/></Style>
    <Style TargetType="ComboBox"><Setter Property="Foreground" Value="#E6E2D4"/><Setter Property="Background" Value="#1A1B12"/><Setter Property="BorderBrush" Value="#7B6A3F"/><Setter Property="BorderThickness" Value="2"/></Style>
    <Style TargetType="ProgressBar"><Setter Property="Background" Value="#080A06"/><Setter Property="Foreground" Value="#50B95B"/><Setter Property="BorderBrush" Value="#5E5739"/><Setter Property="BorderThickness" Value="2"/><Setter Property="Height" Value="13"/></Style>
    <Style TargetType="ScrollBar"><Setter Property="Background" Value="#12140D"/><Setter Property="Foreground" Value="#8FA35D"/><Setter Property="Width" Value="15"/></Style>
    <Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="#D9DDC9"/><Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="6,4"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#55342A18"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#80523B1B"/></Trigger></Style.Triggers></Style>
</ResourceDictionary>