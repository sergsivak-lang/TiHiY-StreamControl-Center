<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingBrush x:Key="StalkerInnerDarkTexture" TileMode="Tile" Viewport="0,0,128,128" ViewportUnits="Absolute" Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#F0080906" Geometry="M0,0 H128 V128 H0 Z"/>
                <GeometryDrawing Brush="#2619160E" Geometry="M0,0 H128 V20 H0 Z M0,70 H128 V76 H0 Z"/>
                <GeometryDrawing Brush="#4A2B140D" Geometry="M7,19 C22,7 48,10 56,27 C45,45 20,43 7,19 Z M71,87 C86,69 114,76 125,98 C111,119 84,114 71,87 Z"/>
                <GeometryDrawing Geometry="M9,41 L79,37 M48,61 L118,57 M11,105 L68,101" Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="#4C76684E" Thickness="1"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M21,8 L25,54 M91,18 L86,68 M55,78 L59,124" Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="#4A000000" Thickness="2"/></GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <DrawingBrush x:Key="StalkerHeaderPlateTexture" TileMode="Tile" Viewport="0,0,320,88" ViewportUnits="Absolute" Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#211E16" Geometry="M0,0 H320 V88 H0 Z"/>
                <GeometryDrawing Brush="#3A2A1A" Geometry="M0,0 H320 V13 H0 Z M0,75 H320 V88 H0 Z"/>
                <GeometryDrawing Brush="#733817" Geometry="M16,9 C51,-2 91,4 110,20 C91,39 47,39 16,9 Z M206,48 C237,29 294,37 317,64 C292,89 239,83 206,48 Z"/>
                <GeometryDrawing Geometry="M0,44 H320" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#6D4E341F" Thickness="2"/></GeometryDrawing.Pen></GeometryDrawing>
                <GeometryDrawing Geometry="M19,30 L112,26 M136,16 L243,13 M174,67 L301,62" Brush="Transparent"><GeometryDrawing.Pen><Pen Brush="#5B87775B" Thickness="1"/></GeometryDrawing.Pen></GeometryDrawing>
                <GeometryDrawing Brush="#8B76664C" Geometry="M8,8 A4,4 0 1 0 16,8 A4,4 0 1 0 8,8 M304,8 A4,4 0 1 0 312,8 A4,4 0 1 0 304,8 M8,72 A4,4 0 1 0 16,72 A4,4 0 1 0 8,72 M304,72 A4,4 0 1 0 312,72 A4,4 0 1 0 304,72"/>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style x:Key="StalkerInnerBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerInnerDarkTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="StalkerListBox" TargetType="ListBox">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="{StaticResource StalkerInnerDarkTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style x:Key="StalkerTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource StalkerExactPanelTexture}"/>
        <Setter Property="BorderBrush" Value="#8B572A"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="5"/>
    </Style>

    <Style x:Key="StalkerTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="#CFC7B2"/>
        <Setter Property="Background" Value="{StaticResource StalkerExactButtonTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Margin" Value="2,2,2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid ClipToBounds="True">
                        <Border x:Name="Plate" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="1"/>
                        <Rectangle Height="6" VerticalAlignment="Top" Margin="3" Fill="{StaticResource StalkerHazardBrush}" Opacity="0.55"/>
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,8,8,5"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True"><Setter TargetName="Plate" Property="BorderBrush" Value="#8FD04D"/><Setter Property="Foreground" Value="#E7D69A"/></Trigger>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Plate" Property="BorderBrush" Value="#D69A35"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="22" Height="22" Margin="0,0,8,0">
                            <Border Background="{StaticResource StalkerExactButtonTexture}" BorderBrush="#76512B" BorderThickness="2"/>
                            <Path x:Name="Check" Data="M4,11 L9,16 L18,5" Stroke="#8FE052" StrokeThickness="3" Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="Check" Property="Visibility" Value="Visible"/></Trigger></ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerProgressBar" TargetType="ProgressBar">
        <Setter Property="Background" Value="#090A07"/>
        <Setter Property="Foreground" Value="#7FCB43"/>
        <Setter Property="BorderBrush" Value="#6D4D2D"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Height" Value="12"/>
    </Style>

    <Style x:Key="StalkerSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="#7FCB43"/>
        <Setter Property="Background" Value="#090A07"/>
        <Setter Property="MinHeight" Value="25"/>
    </Style>

    <Style x:Key="StalkerGroupBox" TargetType="GroupBox">
        <Setter Property="Foreground" Value="#D69A35"/>
        <Setter Property="Background" Value="{StaticResource StalkerExactPanelTexture}"/>
        <Setter Property="BorderBrush" Value="#7D532B"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="4"/>
    </Style>

    <Style x:Key="StalkerWindowHeaderPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerHeaderPlateTexture}"/>
        <Setter Property="BorderBrush" Value="#9A5726"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Effect" Value="{StaticResource StalkerExactPanelShadow}"/>
    </Style>
</ResourceDictionary>