                <GeometryDrawing Brush="#2D292019" Geometry="M0,0 H640 V34 H0 Z M0,386 H640 V420 H0 Z"/>
                <GeometryDrawing Brush="#53301913" Geometry="M18,26 C87,-7 163,7 194,59 C150,116 69,108 18,26 Z M415,271 C479,213 589,236 632,315 C576,398 468,381 415,271 Z"/>
                <GeometryDrawing Brush="#78401B" Geometry="M231,137 C296,91 387,112 416,174 C373,235 278,229 231,137 Z"/>
                <GeometryDrawing Brush="#2A2117" Geometry="M0,118 H640 V123 H0 Z M318,0 H323 V420 H318 Z"/>
                <GeometryDrawing Geometry="M25,100 L244,91 M345,42 L602,34 M74,217 L419,202 M39,347 L263,336 M382,382 L616,366" Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="#60776752" Thickness="1.4"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M105,62 L112,179 M516,86 L499,223 M282,247 L294,395" Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="#65000000" Thickness="4"/></GeometryDrawing.Pen>
                </GeometryDrawing>
