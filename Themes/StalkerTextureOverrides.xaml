                <GeometryDrawing Brush="#11130E" Geometry="M0,0 H256 V42 H0 Z M0,118 H256 V132 H0 Z M0,224 H256 V256 H0 Z"/>
                <GeometryDrawing Brush="#1C1811" Geometry="M0,42 H256 V45 H0 Z M0,132 H256 V135 H0 Z M0,221 H256 V224 H0 Z"/>
                <GeometryDrawing Brush="#4A2511" Geometry="M12,18 C37,2 73,8 91,27 C73,47 37,47 12,18 Z M151,168 C182,139 232,149 249,184 C229,220 177,215 151,168 Z"/>
                <GeometryDrawing Brush="#6B3617" Geometry="M83,82 C110,63 142,72 151,95 C135,118 100,120 83,82 Z M9,203 C31,185 65,190 75,215 C57,238 24,235 9,203 Z"/>
                <GeometryDrawing Geometry="M0,64 H256 M0,192 H256 M64,0 V256 M192,0 V256" Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="#241F1711" Thickness="2"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M17,52 L88,48 M104,21 L177,18 M139,74 L235,69 M27,151 L119,147 M151,233 L241,228 M18,238 L77,230" Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="#607D6D4F" Thickness="1"/></GeometryDrawing.Pen>
