                <GeometryDrawing Brush="#7B6A5C43" Geometry="M12,12 A5,5 0 1 0 22,12 A5,5 0 1 0 12,12 M234,12 A5,5 0 1 0 244,12 A5,5 0 1 0 234,12 M12,234 A5,5 0 1 0 22,234 A5,5 0 1 0 12,234 M234,234 A5,5 0 1 0 244,234 A5,5 0 1 0 234,234"/>
                <GeometryDrawing Brush="#AA120F0A" Geometry="M15,15 A2,2 0 1 0 19,15 A2,2 0 1 0 15,15 M237,15 A2,2 0 1 0 241,15 A2,2 0 1 0 237,15 M15,237 A2,2 0 1 0 19,237 A2,2 0 1 0 15,237 M237,237 A2,2 0 1 0 241,237 A2,2 0 1 0 237,237"/>
