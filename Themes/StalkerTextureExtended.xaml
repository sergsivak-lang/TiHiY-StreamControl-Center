<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="StalkerPasswordBox" TargetType="PasswordBox">
        <Setter Property="Foreground" Value="#E1DCCB"/>
        <Setter Property="Background" Value="{StaticResource StalkerInnerDarkTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="CaretBrush" Value="#86D94B"/>
    </Style>

    <Style x:Key="StalkerRadioButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="22" Height="22" Margin="0,0,8,0">
                            <Ellipse Fill="{StaticResource StalkerExactButtonTexture}" Stroke="#76512B" StrokeThickness="2"/>
                            <Ellipse x:Name="Dot" Width="10" Height="10" Fill="#8FE052" Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="Dot" Property="Visibility" Value="Visible"/></Trigger></ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerDataGrid" TargetType="DataGrid">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="{StaticResource StalkerInnerDarkTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#554029"/>
        <Setter Property="VerticalGridLinesBrush" Value="#3B2D1D"/>
        <Setter Property="RowBackground" Value="#C20B0C08"/>
        <Setter Property="AlternatingRowBackground" Value="#C616150F"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>

    <Style x:Key="StalkerDataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Foreground" Value="#E0B45B"/>
        <Setter Property="Background" Value="{StaticResource StalkerExactButtonTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="0,0,1,2"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="StalkerDataGridRow" TargetType="DataGridRow">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="#C20B0C08"/>
        <Setter Property="BorderBrush" Value="#4C3824"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D12A2418"/></Trigger>
            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#C83D4921"/><Setter Property="Foreground" Value="#F3E9CC"/></Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StalkerTreeView" TargetType="TreeView">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="{StaticResource StalkerInnerDarkTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="6"/>
    </Style>

    <Style x:Key="StalkerTreeViewItem" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Padding" Value="4,3"/>
        <Setter Property="Margin" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#5A332217"/></Trigger>
            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#78424E22"/><Setter Property="Foreground" Value="#E8DDAF"/></Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StalkerScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="#0A0B08"/>
        <Setter Property="Foreground" Value="#80562C"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/></Track.DecreaseRepeatButton>
                            <Track.Thumb><Thumb><Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="{StaticResource StalkerExactButtonTexture}" BorderBrush="#8A5B2D" BorderThickness="2" CornerRadius="1"/></ControlTemplate></Thumb.Template></Thumb></Track.Thumb>
                            <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/></Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerExpander" TargetType="Expander">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="{StaticResource StalkerExactPanelTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Margin" Value="3"/>
    </Style>

    <Style x:Key="StalkerMenu" TargetType="Menu">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="{StaticResource StalkerHeaderPlateTexture}"/>
        <Setter Property="BorderBrush" Value="#73512C"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="StalkerMenuItem" TargetType="MenuItem">
        <Setter Property="Foreground" Value="#DDD8C7"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="9,5"/>
        <Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#68482A18"/><Setter Property="Foreground" Value="#E7C779"/></Trigger></Style.Triggers>
    </Style>
</ResourceDictionary>