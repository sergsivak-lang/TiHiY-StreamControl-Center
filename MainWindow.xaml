<Window x:Class="TiHiY.StreamControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
        xmlns:ui="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="TiHiY StreamControl Center" Width="1600" Height="920" MinWidth="1000" MinHeight="650"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged">
    <Border Style="{StaticResource AppWindowFrame}">
        <Grid Background="{DynamicResource AppBackgroundBrush}">
            <Rectangle Fill="{DynamicResource CircuitBackdropBrush}" IsHitTestVisible="False"/>
            <Grid x:Name="DesignSurface" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="72"/>
                    <RowDefinition Height="58"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="108"/>
                </Grid.RowDefinitions>

                <!-- Full themed title bar -->
                <Border Grid.Row="0" Style="{StaticResource TitleBarBorder}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Cyan}" BorderThickness="1.4" Padding="2" Effect="{DynamicResource CyanGlowEffect}">
                                <Image Source="/TiHiY.StreamControlCenter;component/Assets/AppIcon.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource HeadingFont}" FontSize="26" FontStyle="Italic" FontWeight="Bold">
                                    <Run Text="TiHiY " Foreground="{DynamicResource Cyan}"/>
                                    <Run Text="STREAMCONTROL " Foreground="{DynamicResource Cyan}"/>
                                    <Run Text="CENTER" Foreground="{DynamicResource Accent}"/>
                                </TextBlock>
                                <TextBlock Text="MULTICHAT  •  DONATIONS  •  OBS AUDIO  •  MUSIC" FontSize="10.5" Foreground="{DynamicResource Muted}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock Text="МАСШТАБ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <Button Style="{StaticResource WindowControlButton}" Content="−" Width="38" Click="ZoomOut_Click"/>
                            <Button x:Name="ZoomTextButton" Content="АВТО" MinWidth="92" Height="32" Padding="8,0" Click="ZoomAuto_Click" BorderBrush="{DynamicResource Cyan}"/>
                            <Button Style="{StaticResource WindowControlButton}" Content="+" Width="38" Click="ZoomIn_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource WindowControlButton}" Content="&#xE921;" Click="Minimize_Click" ToolTip="Згорнути"/>
                            <Button Style="{StaticResource WindowControlButton}" Content="&#xE922;" Click="Maximize_Click" ToolTip="Розгорнути"/>
                            <Button Style="{StaticResource WindowControlButton}" Content="&#xE8BB;" Background="{DynamicResource CloseBg}" BorderBrush="{DynamicResource Red}" Click="Close_Click" ToolTip="Закрити"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Status and primary actions -->
                <Border Grid.Row="1" Style="{StaticResource TitleBarBorder}">
                    <Grid Margin="14,7">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource StatusBadgeBorder}" BorderBrush="{DynamicResource Cyan}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7F4;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Cyan}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="ObsDot" Width="9" Height="9" Fill="{DynamicResource Red}" Margin="0,0,7,0"/>
                                    <TextBlock Text="OBS AUDIO" FontWeight="Bold"/>
                                    <TextBlock x:Name="ObsStatusText" Text="  ВІДКЛЮЧЕНО" Foreground="{DynamicResource Red}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatusBadgeBorder}" BorderBrush="{DynamicResource Accent}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE895;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Accent}" Margin="0,0,7,0"/>
                                    <Ellipse Width="9" Height="9" Fill="{DynamicResource Yellow}" Margin="0,0,7,0"/>
                                    <TextBlock Text="MULTISTREAM" FontWeight="Bold"/>
                                    <TextBlock x:Name="BridgeStatusText" Text="  НЕ ПЕРЕВІРЕНО" Foreground="{DynamicResource Yellow}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatusBadgeBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="3" Background="#9147FF" Margin="0,0,6,0"><TextBlock Text="T" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <TextBlock Text="TWITCH: " Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TwitchTopStatusText" Text="OFF" Foreground="#A970FF" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border Width="22" Height="22" CornerRadius="3" Background="#E00000" Margin="12,0,6,0"><TextBlock Text="▶" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <TextBlock Text="YOUTUBE: " Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="YouTubeTopStatusText" Text="OFF" Foreground="#FF5656" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="ПІДКЛЮЧИТИ OBS" ui:CyberUi.IconGlyph="&#xE8A7;" Click="ConnectObs_Click" BorderBrush="{DynamicResource Cyan}"/>
                            <Button Content="КАНАЛИ" ui:CyberUi.IconGlyph="&#xE716;" Click="OpenChannels_Click" BorderBrush="#A970FF"/>
                            <Button Content="YOUTUBE ТРАНСЛЯЦІЯ" ui:CyberUi.IconGlyph="&#xE768;" Click="OpenYouTubeSettings_Click" Background="{DynamicResource DangerBg}" BorderBrush="{DynamicResource Red}"/>
                            <Button Content="НАЛАШТУВАННЯ" ui:CyberUi.IconGlyph="&#xE713;" Click="OpenSettings_Click" BorderBrush="{DynamicResource Cyan}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,10,0,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MainLeftColumn" Width="1.04*" MinWidth="450"/>
                        <ColumnDefinition Width="7"/>
                        <ColumnDefinition x:Name="MainRightColumn" Width="0.96*" MinWidth="420"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="MainTopRow" Height="1.13*" MinHeight="300"/>
                        <RowDefinition Height="7"/>
                        <RowDefinition x:Name="MainBottomRow" Height="0.87*" MinHeight="235"/>
                    </Grid.RowDefinitions>

                    <!-- Multichat -->
                    <ContentControl Grid.Row="0" Grid.Column="0" Style="{StaticResource CyberPanel}" Margin="0,0,7,7">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition/><RowDefinition Height="54"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="МУЛЬТИЧАТ  •  TWITCH + YOUTUBE"/>
                                    <TextBlock x:Name="ChatStatusText" Text="Підключіть канали для реального чату" Foreground="{DynamicResource Muted}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#29134D" BorderBrush="#A970FF" BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="3">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="T" FontWeight="Black" Foreground="White" Background="#9147FF" Padding="6,2"/><TextBlock Text="  ◉ " Foreground="#A970FF"/><TextBlock x:Name="TwitchViewerText" Text="0" FontWeight="Bold"/><TextBlock x:Name="TwitchLiveText" Text="  OFF" Foreground="{DynamicResource Muted}" FontWeight="Bold"/></StackPanel>
                                    </Border>
                                    <Border Background="#341013" BorderBrush="#FF4B4B" BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="3">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="▶" Foreground="White" Background="#E00000" Padding="6,2"/><TextBlock Text="  ◉ " Foreground="#FF5656"/><TextBlock x:Name="YouTubeViewerText" Text="0" FontWeight="Bold"/><TextBlock Text="  ♡ " Foreground="{DynamicResource Red}"/><TextBlock x:Name="YouTubeLikesText" Text="0" FontWeight="Bold"/><TextBlock x:Name="YouTubeLiveText" Text="  OFF" Foreground="{DynamicResource Muted}" FontWeight="Bold"/></StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <ContentControl Grid.Row="1" Style="{StaticResource CyberInsetPanel}" BorderBrush="{DynamicResource Cyan}">
                                <ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}" Background="Transparent" BorderThickness="0" Padding="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Focusable" Value="False"/></Style></ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                                            <Border Background="{Binding Background}" BorderBrush="{DynamicResource ListSeparator}" BorderThickness="0,0,0,0.35" CornerRadius="1" Padding="7,5" Margin="0,1">
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="МУТ НА 10 ХВ" Tag="{Binding}" Click="MuteChatUser_Click"/>
                                                        <MenuItem Header="ЗАБАНИТИ" Tag="{Binding}" Click="BanChatUser_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="ВИДАЛИТИ ПОВІДОМЛЕННЯ" Tag="{Binding}" Click="DeleteChatMessage_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="68"/><ColumnDefinition Width="32"/><ColumnDefinition Width="150"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayTime}" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" Width="22" Height="18" CornerRadius="2" Background="{Binding PlatformColor}" HorizontalAlignment="Left"><TextBlock Text="{Binding PlatformIcon}" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Text}" Foreground="{Binding Foreground}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ContentControl>
                            <Grid Grid.Row="2" Margin="0,7,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="ChatInput" VerticalContentAlignment="Center" KeyDown="ChatInput_KeyDown" ToolTip="Напишіть повідомлення"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="TWITCH" ui:CyberUi.IconGlyph="&#xE8BD;" Click="SendTwitch_Click" Background="#29134D" BorderBrush="#A970FF"/>
                                    <Button Content="YOUTUBE" ui:CyberUi.IconGlyph="&#xE768;" Click="SendYouTube_Click" Background="#341013" BorderBrush="#FF4B4B"/>
                                    <Button Content="В ОБИДВА" ui:CyberUi.IconGlyph="&#xE8A7;" Click="SendBoth_Click" BorderBrush="{DynamicResource Cyan}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ContentControl>

                    <!-- Quick OBS audio mixer -->
                    <ContentControl Grid.Row="0" Grid.Column="2" Style="{StaticResource CyberPanel}" Margin="7,0,0,7">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition/><RowDefinition Height="52"/></Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="ШВИДКИЙ МІКШЕР  •  AUDIO MIXER OBS"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><TextBlock x:Name="AudioPageText" Text="1 / 1" Foreground="{DynamicResource Muted}"/><TextBlock Text="  &#xE713;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Muted}"/></StackPanel>
                            </Grid>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding QuickAudioPage}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="1" Rows="6"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:AudioChannel}">
                                        <Border Background="{DynamicResource PanelDark}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Margin="2.5" Padding="7">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="128"/><ColumnDefinition/><ColumnDefinition Width="70"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                                                <Border Width="34" Height="34" CornerRadius="4" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                                                    <TextBlock Text="{Binding IconGlyph}" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Accent}" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Grid Grid.Column="2" Margin="7,0"><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions><ProgressBar Value="{Binding Meter}" Maximum="1" Height="8" VerticalAlignment="Center"/><Slider Grid.Row="1" Value="{Binding Volume}" Minimum="0" Maximum="1" Tag="{Binding}" ValueChanged="QuickVolumeSlider_ValueChanged"/></Grid>
                                                <TextBlock Grid.Column="3" Text="{Binding DbText}" Foreground="{DynamicResource Accent}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                <Button Grid.Column="4" Content="" ui:CyberUi.IconGlyph="&#xE74F;" Tag="{Binding}" Click="QuickMute_Click" Background="#52212A" BorderBrush="{DynamicResource Red}" Padding="2" Margin="5,1,0,1" ToolTip="{Binding MuteText}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Grid.Row="2" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal"><Button Content="‹" Width="42" Click="PreviousAudioPage_Click"/><Button Content="›" Width="42" Click="NextAudioPage_Click"/></StackPanel>
                                <TextBlock Grid.Column="1" x:Name="AudioStatusText" Text="OBS не підключено" Foreground="{DynamicResource Green}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Button Grid.Column="2" Content="ВІДКРИТИ ПОВНИЙ МІКШЕР" ui:CyberUi.IconGlyph="&#xE9E9;" Click="OpenAudio_Click" Style="{StaticResource AccentButton}"/>
                            </Grid>
                        </Grid>
                    </ContentControl>

                    <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="7" Background="{DynamicResource Accent}" Opacity="0.30" ShowsPreview="True"/>
                    <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Height="7" Background="{DynamicResource Accent}" Opacity="0.30" ShowsPreview="True"/>

                    <!-- Donations -->
                    <ContentControl Grid.Row="2" Grid.Column="0" Style="{StaticResource CyberPanel}" Margin="0,7,7,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="78"/><RowDefinition/><RowDefinition Height="44"/></Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="ДОНАТИ ТА СПОВІЩЕННЯ"/>
                                <TextBlock x:Name="DonatelloStatusText" Text="DONATELLO: OFF • SUPER CHAT • BITS" HorizontalAlignment="Right" Foreground="{DynamicResource Muted}"/>
                            </Grid>
                            <Border Grid.Row="1" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="2" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="165"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Border Width="48" Height="48" CornerRadius="8" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" Effect="{DynamicResource AccentGlowEffect}"><TextBlock Text="&#xE8C7;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Accent}" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="ОСТАННІЙ ДОНАТ" Foreground="{DynamicResource Muted}" FontWeight="Bold"/><TextBlock x:Name="LastDonationAmountText" Text="—" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Yellow}"/></StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"><TextBlock x:Name="LastDonationUserText" Text="Підключіть YouTube/Twitch або Donatello" FontSize="16" FontWeight="Bold"/><TextBlock x:Name="LastDonationMessageText" Text="Super Chat, Super Sticker, Bits і підписки з’являються автоматично після авторизації." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel>
                                </Grid>
                            </Border>
                            <ItemsControl Grid.Row="2" ItemsSource="{Binding DonationPage}" Margin="0,5,0,0">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2" Rows="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DonationEvent}">
                                        <Border Background="{DynamicResource PanelDark}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Margin="2.5" Padding="8">
                                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="&#xE7ED;" FontFamily="{StaticResource IconFont}" Foreground="{Binding Accent}" FontSize="17" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding User}" FontWeight="Bold" Foreground="{Binding Accent}"/><TextBlock Text="{Binding Message}" Foreground="{DynamicResource Muted}" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Grid.Column="2" HorizontalAlignment="Right"><TextBlock Text="{Binding DisplayAmount}" FontWeight="Bold" Foreground="{Binding Accent}"/><TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource Muted}" HorizontalAlignment="Right"/></StackPanel></Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Grid.Row="3" Margin="0,5,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="ЦІЛЬ ЗБОРУ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><ProgressBar x:Name="DonationGoalProgress" Grid.Column="1" Minimum="0" Maximum="1" Height="13" Margin="12,0" VerticalAlignment="Center"/><Button Grid.Column="2" Content="ТЕСТОВИЙ ДОНАТ" ui:CyberUi.IconGlyph="&#xE8C7;" Click="TestDonation_Click" Style="{StaticResource AccentButton}"/></Grid>
                        </Grid>
                    </ContentControl>

                    <!-- Modules -->
                    <ContentControl Grid.Row="2" Grid.Column="2" Style="{StaticResource CyberPanel}" Margin="7,7,0,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="МОДУЛІ"/>
                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,4,0,0">
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE8BD;" Content="ЧАТ&#10;І БОТ" Click="OpenChat_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE7F4;" Content="OVERLAY&#10;OBS" Click="OpenOverlay_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE8D6;" Content="МУЗИКА&#10;NOW PLAYING" Click="OpenMusic_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE9E9;" Content="ПОВНИЙ&#10;АУДІОМІКШЕР" Click="OpenAudio_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE716;" Content="КАНАЛИ&#10;ТА DISCORD" Click="OpenChannels_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE7ED;" Content="СПОВІЩЕННЯ&#10;DISCORD BOT" Click="OpenNotifications_Click" Background="{DynamicResource AccentButtonGradientBrush}" BorderBrush="{DynamicResource Accent}"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE768;" Content="YOUTUBE&#10;STUDIO" Click="OpenYouTubeSettings_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE8C7;" Content="DONATELLO&#10;ДОНАТИ" Click="OpenDonatello_Click" Background="{DynamicResource AccentButtonGradientBrush}" BorderBrush="{DynamicResource Accent}"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE713;" Content="НАЛАШТУВАННЯ" Click="OpenSettings_Click"/>
                                <Button Style="{StaticResource ModuleButton}" ui:CyberUi.IconGlyph="&#xE8A5;" Content="ЖУРНАЛ&#10;ПОДІЙ" Click="OpenJournal_Click"/>
                            </UniformGrid>
                        </Grid>
                    </ContentControl>
                </Grid>

                <!-- Footer -->
                <ContentControl Grid.Row="3" Style="{StaticResource CyberPanel}" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="2.25*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="38" Height="38" CornerRadius="5" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Cyan}" BorderThickness="1"><TextBlock Text="&#xE950;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Cyan}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1"><TextBlock Text="СТАН СИСТЕМИ" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><TextBlock x:Name="SystemStateText" Text="Очікування підключення OBS" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/></StackPanel></Grid>
                        <Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="38" Height="38" CornerRadius="5" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Cyan}" BorderThickness="1"><TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Cyan}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1"><TextBlock Text="ОСТАННЯ ПОДІЯ" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><TextBlock x:Name="LastLogText" Text="TiHiY StreamControl Center готовий" Foreground="{DynamicResource Muted}" TextTrimming="CharacterEllipsis"/></StackPanel></Grid>
                        <Button Grid.Column="2" Content="ВІДКРИТИ ЖУРНАЛ" ui:CyberUi.IconGlyph="&#xE8A5;" Click="OpenJournal_Click" VerticalAlignment="Center" Style="{StaticResource AccentButton}"/>
                    </Grid>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
