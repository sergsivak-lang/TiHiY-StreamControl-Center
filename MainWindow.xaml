                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE950;" FontSize="25"/>
