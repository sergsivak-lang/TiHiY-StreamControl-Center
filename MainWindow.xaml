<Window x:Class="TiHiY.StreamControlCenter.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
 Title="TiHiY StreamControl Center — STALKER Mode" Width="1672" Height="941" MinWidth="1180" MinHeight="720"
 WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
 Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged"
 PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
 <Window.Resources>
  <Style x:Key="PanelTitle" TargetType="TextBlock"><Setter Property="Foreground" Value="#E1D9C1"/><Setter Property="FontFamily" Value="Bahnschrift Condensed, Segoe UI"/><Setter Property="FontSize" Value="20"/><Setter Property="FontWeight" Value="Black"/></Style>
  <Style x:Key="TinyLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="#969078"/><Setter Property="FontSize" Value="11.5"/></Style>
  <Style x:Key="LayoutSplitter" TargetType="GridSplitter"><Setter Property="Background" Value="Transparent"/><Setter Property="ShowsPreview" Value="False"/></Style>
  <Style x:Key="SteelPanel" TargetType="ContentControl" BasedOn="{StaticResource HudPanel}"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="14"/></Style>
  <Style x:Key="TopStatus" TargetType="Border" BasedOn="{StaticResource StatusPill}"><Setter Property="MinHeight" Value="46"/><Setter Property="Margin" Value="4,2"/><Setter Property="Padding" Value="13,7"/></Style>
  <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource CyberInnerBorder}"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="8"/></Style>
 </Window.Resources>
 <Border Background="{DynamicResource WindowGradient}" BorderBrush="#887749" BorderThickness="2">
  <Grid x:Name="DesignSurface" Margin="12">
   <Grid.RowDefinitions><RowDefinition Height="134"/><RowDefinition Height="*"/><RowDefinition Height="226"/><RowDefinition Height="38"/></Grid.RowDefinitions>

   <!-- HEADER -->
   <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="58"/></Grid.RowDefinitions>
    <Grid.ColumnDefinitions><ColumnDefinition Width="1.16*"/><ColumnDefinition Width="1.06*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
     <Grid Width="68" Height="68"><Ellipse Fill="#11120C" Stroke="#A18746" StrokeThickness="3"/><Ellipse Margin="7" Stroke="#4F4930" StrokeThickness="2"/><TextBlock Text="☢" FontFamily="Segoe UI Symbol" FontSize="41" Foreground="#C99A35" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
     <StackPanel Margin="14,0,0,0" VerticalAlignment="Center"><TextBlock Text="TIHIY STREAMCONTROL CENTER" FontFamily="Bahnschrift Condensed, Impact" FontSize="36" FontWeight="Black" Foreground="#E0D8C2"/><TextBlock Text="СТАЛКЕР РЕЖИМ  •  ПОВНИЙ КОНТРОЛЬ СТРІМУ" FontSize="13.5" FontWeight="Bold" Foreground="#A9A083"/></StackPanel>
    </StackPanel>
    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
     <Button Click="OpenSettings_Click" MinWidth="150" Height="42"><StackPanel Orientation="Horizontal"><TextBlock Text="⚙" FontSize="17"/><TextBlock Text="  НАЛАШТУВАННЯ"/></StackPanel></Button>
     <Button Click="OpenOverlay_Click" MinWidth="144" Height="42"><StackPanel Orientation="Horizontal"><TextBlock Text="▣" FontSize="17" Foreground="#BD513B"/><TextBlock Text="  ТРАНСЛЯЦІЯ"/></StackPanel></Button>
     <Button Click="OpenMusic_Click" MinWidth="166" Height="42"><StackPanel Orientation="Horizontal"><TextBlock Text="♫" FontSize="18" Foreground="#D6A03D"/><TextBlock Text="  МУЗИЧНИЙ ПЛЕЄР"/></StackPanel></Button>
    </StackPanel>
    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,2,0"><TextBlock Text="МАСШТАБ" VerticalAlignment="Center" Margin="0,0,7,0" Foreground="#918B72"/><Button Content="−" Width="38" Height="34" Click="ZoomOut_Click"/><Button x:Name="ZoomTextButton" Content="100%" Width="68" Height="34" Click="ZoomAuto_Click"/><Button Content="+" Width="38" Height="34" Click="ZoomIn_Click"/><Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/><Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/><Button Style="{StaticResource DangerButton}" Content="×" Width="38" Height="32" Click="Close_Click"/></StackPanel>
    <UniformGrid Grid.Row="1" Grid.ColumnSpan="3" Columns="4" Margin="2,4,2,4">
     <Border Style="{StaticResource TopStatus}"><StackPanel Orientation="Horizontal"><Ellipse x:Name="ObsDot" Width="11" Height="11" Fill="{DynamicResource Red}"/><StackPanel Margin="9,0,0,0"><TextBlock Text="OBS AUDIO" FontWeight="Bold"/><TextBlock x:Name="ObsStatusText" Text="ВІДКЛЮЧЕНО" Foreground="{DynamicResource Red}" FontWeight="Bold"/></StackPanel></StackPanel></Border>
     <Border Style="{StaticResource TopStatus}"><StackPanel Orientation="Horizontal"><Ellipse x:Name="BridgeDot" Width="11" Height="11" Fill="{DynamicResource Yellow}"/><StackPanel Margin="9,0,0,0"><TextBlock Text="MULTISTREAM" FontWeight="Bold"/><TextBlock x:Name="BridgeStatusText" Text="НЕ ПЕРЕВІРЕНО" Foreground="{DynamicResource Yellow}" FontWeight="Bold"/></StackPanel></StackPanel></Border>
     <Border Style="{StaticResource TopStatus}" BorderBrush="#66507A"><StackPanel Orientation="Horizontal"><TextBlock Text="▣" Foreground="#A879D1" FontSize="20"/><StackPanel Margin="9,0,0,0"><TextBlock Text="TWITCH" FontWeight="Bold"/><TextBlock x:Name="TwitchTopStatusText" Text="OFF" Foreground="#A879D1" FontWeight="Bold"/></StackPanel></StackPanel></Border>
     <Border Style="{StaticResource TopStatus}" BorderBrush="#7F463B"><StackPanel Orientation="Horizontal"><TextBlock Text="▶" Foreground="#CC4F42" FontSize="19"/><StackPanel Margin="9,0,0,0"><TextBlock Text="YOUTUBE" FontWeight="Bold"/><TextBlock x:Name="YouTubeTopStatusText" Text="OFF" Foreground="#CC4F42" FontWeight="Bold"/></StackPanel></StackPanel></Border>
    </UniformGrid>
   </Grid>

   <!-- MAIN 2x2 -->
   <Grid x:Name="DashboardBlocksGrid" Grid.Row="1">
    <Grid.ColumnDefinitions><ColumnDefinition x:Name="TopLeftColumn" Width="1.03*"/><ColumnDefinition Width="8"/><ColumnDefinition x:Name="TopRightColumn" Width="1*"/></Grid.ColumnDefinitions>
    <Grid.RowDefinitions><RowDefinition x:Name="MainTopRow" Height="1.14*"/><RowDefinition Height="8"/><RowDefinition x:Name="MainBottomRow" Height="1*"/></Grid.RowDefinitions>
    <GridSplitter Grid.Column="1" Grid.RowSpan="3" Style="{StaticResource LayoutSplitter}" ResizeDirection="Columns" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/><GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource LayoutSplitter}" ResizeDirection="Rows" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>

    <ContentControl x:Name="ChatBlockPanel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition Height="*"/><RowDefinition Height="48"/></Grid.RowDefinitions>
      <Grid><StackPanel><TextBlock Text="МУЛЬТИЧАТ • TWITCH + YOUTUBE" Style="{StaticResource PanelTitle}"/><TextBlock x:Name="ChatStatusText" Text="Єдиний чат • синхронізація повідомлень" Style="{StaticResource TinyLabel}"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Border Style="{StaticResource StatusPill}"><StackPanel Orientation="Horizontal"><TextBlock Text="TW "/><TextBlock x:Name="TwitchViewerText" Text="0" FontWeight="Bold"/><Ellipse x:Name="TwitchLiveDot" Width="8" Height="8" Margin="8,0,4,0"/><TextBlock x:Name="TwitchLiveText" Text="OFF"/></StackPanel></Border><Border Style="{StaticResource StatusPill}"><StackPanel Orientation="Horizontal"><TextBlock Text="YT "/><TextBlock x:Name="YouTubeViewerText" Text="0" FontWeight="Bold"/><TextBlock Text="  ♥ "/><TextBlock x:Name="YouTubeLikesText" Text="0" FontWeight="Bold"/><Ellipse x:Name="YouTubeLiveDot" Width="8" Height="8" Margin="8,0,4,0"/><TextBlock x:Name="YouTubeLiveText" Text="OFF"/></StackPanel></Border></StackPanel></Grid>
      <Border Grid.Row="1" Background="#EE070905" BorderBrush="#5B5338" BorderThickness="1"><Grid><ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}" PreviewMouseRightButtonDown="MainChatList_PreviewMouseRightButtonDown" ScrollViewer.VerticalScrollBarVisibility="Auto"><ListBox.ItemTemplate><DataTemplate DataType="{x:Type models:ChatMessage}"><Border BorderBrush="#2B2B20" BorderThickness="0,0,0,1" Padding="6,5"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="76"/><ColumnDefinition Width="30"/><ColumnDefinition Width="145"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding DisplayTime}" Foreground="#7D7964"/><Border Grid.Column="1" Width="18" Height="18" CornerRadius="3" Background="{Binding PlatformColor}"/><TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold"/><TextBlock Grid.Column="3" Text="{Binding Text}" TextWrapping="Wrap" Foreground="#D7D1BC"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox><TextBlock x:Name="ChatEmptyStateText" Text="Очікування повідомлень…" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid></Border>
      <Grid Grid.Row="2" Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="112"/><ColumnDefinition Width="112"/><ColumnDefinition Width="112"/></Grid.ColumnDefinitions><TextBox x:Name="ChatInput" KeyDown="ChatInput_KeyDown" VerticalContentAlignment="Center"/><Button x:Name="SendTwitchButton" Grid.Column="1" Content="TWITCH" Click="SendTwitch_Click"/><Button x:Name="SendYouTubeButton" Grid.Column="2" Content="YOUTUBE" Click="SendYouTube_Click"/><Button x:Name="SendBothButton" Grid.Column="3" Content="ОБИДВА" Click="SendBoth_Click"/></Grid>
     </Grid>
    </ContentControl>

    <ContentControl x:Name="DonationsBlockPanel" Grid.Row="0" Grid.Column="2" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions><Grid><TextBlock Text="ДОНАТИ" Style="{StaticResource PanelTitle}"/><TextBlock x:Name="DonatelloStatusText" HorizontalAlignment="Right" VerticalAlignment="Center" Text="DONATELLO • SUPER CHAT • BITS" Foreground="#8FA964"/></Grid>
      <Border Grid.Row="1" Background="#EE070905" BorderBrush="#5B5338" BorderThickness="1"><Grid><ItemsControl ItemsSource="{Binding RecentDonations}"><ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:DonationEvent}"><Border BorderBrush="#3B392B" BorderThickness="0,0,0,1" Padding="14,9"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/><ColumnDefinition Width="92"/></Grid.ColumnDefinitions><Border Width="44" Height="44" CornerRadius="22" BorderBrush="#755D31" BorderThickness="2"><TextBlock Text="♥" FontSize="22" Foreground="#D3A14B" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1"><TextBlock Text="{Binding User}" FontSize="17" FontWeight="Bold" Foreground="#E3DCC7"/><TextBlock Text="{Binding DisplayAmount}" FontSize="24" Foreground="#E0A43E" FontWeight="Black"/><TextBlock Text="{Binding Message}" Foreground="#B2AD94" TextWrapping="Wrap"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding DisplayTime}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#8D8971"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="RecentDonationsEmptyText" Text="Донатів ще немає" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid></Border><Button Grid.Row="2" Content="ВІДКРИТИ ДОНАТИ / ВІДЖЕТИ" Click="OpenDonatello_Click"/>
     </Grid>
    </ContentControl>

    <ContentControl x:Name="MixerBlockPanel" Grid.Row="2" Grid.Column="0" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="40"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="ШВИДКИЙ МІКШЕР • AUDIO MIXER OBS" Style="{StaticResource PanelTitle}"/><TextBlock x:Name="AudioStatusText" Text="OBS Audio" Style="{StaticResource TinyLabel}"/></StackPanel><TextBlock x:Name="AudioPageText" Text="0 / 0" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid><Grid Grid.Row="1"><ItemsControl ItemsSource="{Binding QuickAudioPage}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="4,3"><Grid.ColumnDefinitions><ColumnDefinition Width="165"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold"/><Grid Grid.Column="1" Margin="8,0"><ProgressBar Value="{Binding Meter}" Maximum="1" Height="13" VerticalAlignment="Center"/><Slider Value="{Binding Volume}" Maximum="1" Height="26" Tag="{Binding}" ValueChanged="QuickVolumeSlider_ValueChanged" Opacity="0.01"/></Grid><TextBlock Grid.Column="2" Text="{Binding Db, StringFormat={}{0:0.0} dB}" Foreground="#DCA13B" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold"/><Button Grid.Column="3" Content="M" Tag="{Binding}" Click="QuickMute_Click"/></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="AudioEmptyStateText" Text="Підключіть OBS" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid><Grid Grid.Row="2"><Button Content="ВІДКРИТИ ПОВНИЙ МІКШЕР" Click="OpenAudio_Click" HorizontalAlignment="Right"/></Grid></Grid>
    </ContentControl>

    <ContentControl x:Name="NotificationsBlockPanel" Grid.Row="2" Grid.Column="2" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions><Grid><TextBlock Text="СПОВІЩЕННЯ" Style="{StaticResource PanelTitle}"/><TextBlock Text="DONATELLO • DISCORD BOT" HorizontalAlignment="Right" Foreground="#8FA964" VerticalAlignment="Center"/></Grid><Border Grid.Row="1" Background="#EE070905" BorderBrush="#5B5338" BorderThickness="1"><Grid><ItemsControl ItemsSource="{Binding DonationPage}"><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="#37362A" BorderThickness="0,0,0,1" Padding="9,7"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="145"/><ColumnDefinition Width="*"/><ColumnDefinition Width="85"/></Grid.ColumnDefinitions><TextBlock Text="♥" Foreground="#D0A050"/><TextBlock Grid.Column="1" Text="{Binding User}" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="{Binding EventSummary}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="3" Text="{Binding DisplayTime}" Foreground="#8A8770"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="DonationEmptyStateText" Text="Подій ще немає" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid></Border><Grid Grid.Row="2"><TextBlock x:Name="LastNotificationText" VerticalAlignment="Center" Foreground="#A9A58D"/><TextBlock x:Name="LastNotificationTimeText" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#8A8770"/><Button Content="ВІДКРИТИ ПОВНИЙ ЖУРНАЛ" Click="OpenJournal_Click" HorizontalAlignment="Center"/></Grid></Grid>
    </ContentControl>
   </Grid>

   <!-- BOTTOM TRIPTYCH -->
   <Grid Grid.Row="2" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition x:Name="FooterSystemColumn" Width="1.02*"/><ColumnDefinition Width="8"/><ColumnDefinition x:Name="FooterEventsColumn" Width="0.94*"/><ColumnDefinition Width="8"/><ColumnDefinition x:Name="FooterMonitorColumn" Width="1.04*"/></Grid.ColumnDefinitions>
    <ContentControl x:Name="SystemStatusBlockPanel" Grid.Column="0" Style="{StaticResource SteelPanel}" AllowDrop="True"><Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="СТАН СИСТЕМИ" Style="{StaticResource PanelTitle}"/><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.12*"/><ColumnDefinition Width="0.88*"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock x:Name="SystemObsText" Margin="0,3"/><TextBlock x:Name="SystemTwitchText" Margin="0,3"/><TextBlock x:Name="SystemYouTubeText" Margin="0,3"/><TextBlock x:Name="SystemOverlayText" Margin="0,3"/><TextBlock x:Name="SystemDonatelloText" Margin="0,3"/><TextBlock x:Name="SystemDiscordText" Margin="0,3"/></StackPanel><StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="СТАН:" Foreground="#8A8770"/><TextBlock x:Name="AllSystemsStatusText" FontWeight="Bold" FontSize="14"/><TextBlock x:Name="SystemStateText" TextWrapping="Wrap" Foreground="#AAA68E" Margin="0,9,0,0"/><TextBlock x:Name="LastLogText" TextWrapping="Wrap" Foreground="#77745F" Margin="0,8,0,0"/></StackPanel></Grid></Grid></ContentControl>

    <ContentControl x:Name="ModulesBlockPanel" Grid.Column="2" Style="{StaticResource SteelPanel}" AllowDrop="True"><Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions><Grid Background="#F0080906" ClipToBounds="True"><Canvas IsHitTestVisible="False" Opacity="0.9"><Rectangle Width="520" Height="184" Fill="#080906"/><Path Fill="#191C13" Data="M0,145 L0,110 L34,110 L34,82 L51,82 L51,110 L95,110 L95,54 L106,54 L106,110 L148,110 L148,74 L167,74 L167,110 L216,110 L216,42 L228,42 L228,110 L276,110 L276,69 L292,69 L292,110 L340,110 L340,35 L352,35 L352,110 L398,110 L398,63 L414,63 L414,110 L456,110 L456,48 L468,48 L468,110 L520,110 L520,184 L0,184 Z"/><Path Stroke="#4F472F" StrokeThickness="2" Data="M106,54 V24 M101,24 H111 M228,42 V15 M223,15 H233 M346,35 V8 M341,8 H351 M462,48 V20 M457,20 H467"/><Path Stroke="#7B673D" StrokeThickness="1" Opacity="0.55" Data="M12,18 L170,13 M278,20 L500,14 M35,155 L210,160 M290,157 L500,162"/></Canvas><Border Background="#36000000"/><Grid HorizontalAlignment="Center" VerticalAlignment="Center"><Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Grid Width="68" Height="68"><Ellipse Fill="#17170F" Stroke="#95783B" StrokeThickness="2"/><Ellipse Margin="9" Stroke="#51482D"/><TextBlock Text="☢" FontFamily="Segoe UI Symbol" FontSize="36" Foreground="#C89739" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid><StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="STALKER" FontFamily="Bahnschrift Condensed, Impact" FontSize="54" FontWeight="Black" Foreground="#E4DCC5"/><TextBlock Text="ЗОНА ЧЕКАЄ НА ТЕБЕ..." FontSize="17" FontWeight="Bold" Foreground="#C5A057" HorizontalAlignment="Center"/></StackPanel></Grid></Grid><UniformGrid Grid.Row="1" Columns="4"><Button Content="ЧАТ-БОТ" Click="OpenChat_Click"/><Button Content="OVERLAY" Click="OpenOverlay_Click"/><Button Content="МУЗИКА" Click="OpenMusic_Click"/><Button Content="СПОВІЩЕННЯ" Click="OpenNotifications_Click"/></UniformGrid></Grid></ContentControl>

    <ContentControl x:Name="SystemMonitorPanel" Grid.Column="4" Style="{StaticResource SteelPanel}" AllowDrop="True"><Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="30"/></Grid.RowDefinitions><Grid><TextBlock Text="МОНІТОРИНГ ПК" Style="{StaticResource PanelTitle}"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Ellipse x:Name="AidaStatusDot" Width="8" Height="8"/><TextBlock x:Name="AidaStatusText" Text="WINDOWS" Margin="5,0"/><TextBlock x:Name="SystemClockText"/></StackPanel></Grid><UniformGrid Grid.Row="1" Columns="4"><Border Style="{StaticResource MetricCard}"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="CPU" FontSize="15" FontWeight="Bold"/><TextBlock x:Name="CpuLoadMonitorText" Text="— %" FontSize="31" Foreground="#A7CB70"/><ProgressBar Value="12" Maximum="100" Height="7" Width="90"/><TextBlock x:Name="CpuClockMonitorText"/><TextBlock x:Name="CpuTemperatureMonitorText"/></StackPanel></Border><Border Style="{StaticResource MetricCard}"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="GPU" FontSize="15" FontWeight="Bold"/><TextBlock x:Name="GpuLoadMonitorText" Text="— %" FontSize="31" Foreground="#A7CB70"/><ProgressBar Value="27" Maximum="100" Height="7" Width="90"/><TextBlock x:Name="GpuTemperatureMonitorText"/></StackPanel></Border><Border Style="{StaticResource MetricCard}"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="RAM" FontSize="15" FontWeight="Bold"/><TextBlock x:Name="RamLoadMonitorText" Text="—" FontSize="24" Foreground="#A7CB70"/><ProgressBar Value="20" Maximum="100" Height="7" Width="90"/><TextBlock x:Name="MemoryClockMonitorText"/><TextBlock x:Name="VramLoadMonitorText"/></StackPanel></Border><Border Style="{StaticResource MetricCard}"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="FPS" FontSize="15" FontWeight="Bold"/><TextBlock Text="60" FontSize="42" Foreground="#A7CB70"/><TextBlock Text="OVERLAY" Foreground="#8EA55A"/><TextBlock x:Name="ObsFpsText"/><TextBlock x:Name="UptimeText"/></StackPanel></Border></UniformGrid><TextBlock Grid.Row="2" x:Name="NetworkText" HorizontalAlignment="Center" Foreground="#8A9C66"/></Grid></ContentControl>
   </Grid>

   <Border Grid.Row="3" Background="#ED0B0D08" BorderBrush="#625638" BorderThickness="1" Margin="4,6,4,0"><Grid Margin="12,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="●  STALKER MODE ACTIVE" Foreground="#91B45F" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="TiHiY StreamControl Center" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8A8770"/><TextBlock Grid.Column="2" Text="ПОВНИЙ КОНТРОЛЬ ТВОГО СТРІМУ" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8A8770"/><TextBlock Grid.Column="3" Text="20:39:45" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#C8B98A"/></Grid></Border>

   <Grid Visibility="Collapsed"><Grid.ColumnDefinitions><ColumnDefinition x:Name="BottomLeftColumn"/><ColumnDefinition x:Name="BottomRightColumn"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition x:Name="FooterRow" Height="180"/></Grid.RowDefinitions><Button x:Name="ConnectObsButton" Click="ConnectObs_Click"><TextBlock x:Name="ConnectObsButtonText"/></Button><Button x:Name="LayoutEditButton" Click="ToggleLayoutEdit_Click"/></Grid>
  </Grid>
 </Border>
</Window>