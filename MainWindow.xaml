<Window x:Class="TiHiY.StreamControlCenter.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
 Title="TiHiY StreamControl Center — STALKER Mode" Width="1672" Height="941" MinWidth="1180" MinHeight="720"
 WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
 Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged"
 PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
 <Window.Resources>
  <Style x:Key="HeaderText" TargetType="TextBlock"><Setter Property="Foreground" Value="#D7D0B6"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="18"/><Setter Property="FontFamily" Value="Bahnschrift Condensed, Segoe UI"/></Style>
  <Style x:Key="TinyLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="#8D8A72"/><Setter Property="FontSize" Value="11"/></Style>
  <Style x:Key="PanelTitle" TargetType="TextBlock"><Setter Property="Foreground" Value="#D8D0B6"/><Setter Property="FontSize" Value="19"/><Setter Property="FontWeight" Value="Black"/><Setter Property="FontFamily" Value="Bahnschrift Condensed, Segoe UI"/></Style>
  <Style x:Key="LayoutSplitter" TargetType="GridSplitter"><Setter Property="Background" Value="Transparent"/><Setter Property="ShowsPreview" Value="False"/></Style>
  <Style x:Key="IconGlyph" TargetType="TextBlock"><Setter Property="FontFamily" Value="Segoe MDL2 Assets"/><Setter Property="FontSize" Value="18"/><Setter Property="Foreground" Value="#C79539"/></Style>
  <Style x:Key="SteelPanel" TargetType="ContentControl" BasedOn="{StaticResource HudPanel}"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="14"/></Style>
 </Window.Resources>
 <Border Background="{DynamicResource WindowGradient}" BorderBrush="#6F623C" BorderThickness="2">
  <Grid x:Name="DesignSurface" Margin="12">
   <Grid.RowDefinitions>
    <RowDefinition Height="126"/>
    <RowDefinition Height="*"/>
    <RowDefinition Height="220"/>
    <RowDefinition Height="38"/>
   </Grid.RowDefinitions>

   <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,4,0,4">
     <Grid Width="82" Height="82">
      <Ellipse Fill="#15150D" Stroke="#A78A48" StrokeThickness="3"/>
      <Ellipse Margin="8" Stroke="#665C39" StrokeThickness="2"/>
      <TextBlock Text="☢" FontFamily="Segoe UI Symbol" FontSize="48" Foreground="#C49939" HorizontalAlignment="Center" VerticalAlignment="Center"/>
     </Grid>
     <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
      <TextBlock Text="TIHIY STREAMCONTROL CENTER" FontFamily="Bahnschrift Condensed, Impact" FontSize="37" FontWeight="Black" Foreground="#D3CCB7"/>
      <TextBlock Text="СТАЛКЕР РЕЖИМ  •  ПОВНИЙ КОНТРОЛЬ СТРІМУ" FontSize="14" FontWeight="Bold" Foreground="#9C967D"/>
     </StackPanel>
    </StackPanel>
    <WrapPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
     <Border Style="{StaticResource StatusPill}"><StackPanel Orientation="Horizontal"><Ellipse x:Name="ObsDot" Width="9" Height="9" Fill="{DynamicResource Red}"/><TextBlock Text="  OBS AUDIO" FontWeight="Bold"/><TextBlock x:Name="ObsStatusText" Text="  ВІДКЛЮЧЕНО" Foreground="{DynamicResource Red}" FontWeight="Bold"/></StackPanel></Border>
     <Border Style="{StaticResource StatusPill}"><StackPanel Orientation="Horizontal"><Ellipse x:Name="BridgeDot" Width="9" Height="9" Fill="{DynamicResource Yellow}"/><TextBlock Text="  MULTISTREAM" FontWeight="Bold"/><TextBlock x:Name="BridgeStatusText" Text="  НЕ ПЕРЕВІРЕНО" Foreground="{DynamicResource Yellow}" FontWeight="Bold"/></StackPanel></Border>
     <Border Style="{StaticResource StatusPill}"><TextBlock><Run Text="TWITCH  "/><Run x:Name="TwitchTopStatusText" Text="OFF"/></TextBlock></Border>
     <Border Style="{StaticResource StatusPill}"><TextBlock><Run Text="YOUTUBE  "/><Run x:Name="YouTubeTopStatusText" Text="OFF"/></TextBlock></Border>
    </WrapPanel>
    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,6,4,0">
     <TextBlock Text="МАСШТАБ" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#918B72"/>
     <Button Content="−" Width="38" Height="32" Click="ZoomOut_Click"/>
     <Button x:Name="ZoomTextButton" Content="100%" Width="68" Height="32" Click="ZoomAuto_Click"/>
     <Button Content="+" Width="38" Height="32" Click="ZoomIn_Click"/>
     <Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/>
     <Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/>
     <Button Style="{StaticResource DangerButton}" Content="×" Width="38" Height="30" Click="Close_Click"/>
    </StackPanel>
    <UniformGrid Grid.Column="1" Columns="3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
     <Button Click="OpenSettings_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="⚙"/><TextBlock Text="  НАЛАШТУВАННЯ"/></StackPanel></Button>
     <Button Click="OpenOverlay_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="▣"/><TextBlock Text="  ТРАНСЛЯЦІЯ"/></StackPanel></Button>
     <Button Click="OpenMusic_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="♫"/><TextBlock Text="  МУЗИЧНИЙ ПЛЕЄР"/></StackPanel></Button>
    </UniformGrid>
   </Grid>

   <Grid x:Name="DashboardBlocksGrid" Grid.Row="1">
    <Grid.ColumnDefinitions><ColumnDefinition x:Name="TopLeftColumn" Width="1*"/><ColumnDefinition Width="8"/><ColumnDefinition x:Name="TopRightColumn" Width="1*"/></Grid.ColumnDefinitions>
    <Grid.RowDefinitions><RowDefinition x:Name="MainTopRow" Height="1*"/><RowDefinition Height="8"/><RowDefinition x:Name="MainBottomRow" Height="1*"/></Grid.RowDefinitions>
    <GridSplitter Grid.Column="1" Grid.RowSpan="3" Style="{StaticResource LayoutSplitter}" ResizeDirection="Columns" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>
    <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource LayoutSplitter}" ResizeDirection="Rows" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>

    <ContentControl x:Name="ChatBlockPanel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="48"/></Grid.RowDefinitions>
      <Grid><StackPanel><TextBlock Text="МУЛЬТИЧАТ • TWITCH + YOUTUBE" Style="{StaticResource PanelTitle}"/><TextBlock x:Name="ChatStatusText" Text="Єдиний чат • синхронізація повідомлень" Style="{StaticResource TinyLabel}"/></StackPanel>
       <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Border Style="{StaticResource StatusPill}"><StackPanel Orientation="Horizontal"><TextBlock Text="TW "/><TextBlock x:Name="TwitchViewerText" Text="0"/><Ellipse x:Name="TwitchLiveDot" Width="8" Height="8" Margin="8,0,4,0"/><TextBlock x:Name="TwitchLiveText" Text="OFF"/></StackPanel></Border><Border Style="{StaticResource StatusPill}"><StackPanel Orientation="Horizontal"><TextBlock Text="YT "/><TextBlock x:Name="YouTubeViewerText" Text="0"/><TextBlock Text="  ♥ "/><TextBlock x:Name="YouTubeLikesText" Text="0"/><Ellipse x:Name="YouTubeLiveDot" Width="8" Height="8" Margin="8,0,4,0"/><TextBlock x:Name="YouTubeLiveText" Text="OFF"/></StackPanel></Border></StackPanel>
      </Grid>
      <Border Grid.Row="1" Background="#D9080A06" BorderBrush="#5E5638" BorderThickness="1"><Grid>
       <ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}" PreviewMouseRightButtonDown="MainChatList_PreviewMouseRightButtonDown" ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemTemplate><DataTemplate DataType="{x:Type models:ChatMessage}"><Grid Margin="4"><Grid.ColumnDefinitions><ColumnDefinition Width="74"/><ColumnDefinition Width="125"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding DisplayTime}" Foreground="#787663"/><TextBlock Grid.Column="1" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="{Binding Text}" TextWrapping="Wrap"/></Grid></DataTemplate></ListBox.ItemTemplate>
       </ListBox><TextBlock x:Name="ChatEmptyStateText" Text="Очікування повідомлень…" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid></Border>
      <Grid Grid.Row="2" Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBox x:Name="ChatInput" KeyDown="ChatInput_KeyDown" VerticalContentAlignment="Center"/><Button x:Name="SendTwitchButton" Grid.Column="1" Content="TWITCH" Click="SendTwitch_Click"/><Button x:Name="SendYouTubeButton" Grid.Column="2" Content="YOUTUBE" Click="SendYouTube_Click"/><Button x:Name="SendBothButton" Grid.Column="3" Content="ОБИДВА" Click="SendBoth_Click"/></Grid>
     </Grid>
    </ContentControl>

    <ContentControl x:Name="DonationsBlockPanel" Grid.Row="0" Grid.Column="2" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="45"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions><Grid><TextBlock Text="ДОНАТИ" Style="{StaticResource PanelTitle}"/><TextBlock x:Name="DonatelloStatusText" HorizontalAlignment="Right" VerticalAlignment="Center" Text="DONATELLO • SUPER CHAT • BITS" Foreground="#88A45D"/></Grid>
      <Border Grid.Row="1" Background="#D9080A06" BorderBrush="#5E5638" BorderThickness="1"><Grid><ItemsControl ItemsSource="{Binding RecentDonations}"><ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:DonationEvent}"><Border BorderBrush="#3B3828" BorderThickness="0,0,0,1" Padding="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="55"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="♥" FontSize="24" Foreground="#C99A45"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding User}" FontSize="16" FontWeight="Bold"/><TextBlock Text="{Binding DisplayAmount}" FontSize="22" Foreground="#D8A13C" FontWeight="Bold"/><TextBlock Text="{Binding Message}" Foreground="#AAA68E"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding DisplayTime}" HorizontalAlignment="Right" Foreground="#8A8770"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="RecentDonationsEmptyText" Text="Донатів ще немає" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid></Border>
      <Button Grid.Row="2" Content="ВІДКРИТИ ДОНАТИ / ВІДЖЕТИ" Click="OpenDonatello_Click"/>
     </Grid>
    </ContentControl>

    <ContentControl x:Name="MixerBlockPanel" Grid.Row="2" Grid.Column="0" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="*"/><RowDefinition Height="40"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="ШВИДКИЙ МІКШЕР • AUDIO MIXER OBS" Style="{StaticResource PanelTitle}"/><TextBlock x:Name="AudioStatusText" Text="OBS Audio" Style="{StaticResource TinyLabel}"/></StackPanel><TextBlock x:Name="AudioPageText" Text="0 / 0" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
      <Grid Grid.Row="1"><ItemsControl ItemsSource="{Binding QuickAudioPage}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}" VerticalAlignment="Center"/><ProgressBar Grid.Column="1" Value="{Binding Meter}" Maximum="1" Height="12" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Db, StringFormat={}{0:0.0} dB}" Foreground="#D69C38" VerticalAlignment="Center" HorizontalAlignment="Right"/><Button Grid.Column="3" Content="M" Tag="{Binding}" Click="QuickMute_Click"/></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="AudioEmptyStateText" Text="Підключіть OBS" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid>
      <Grid Grid.Row="2"><Button Content="ВІДКРИТИ ПОВНИЙ МІКШЕР" Click="OpenAudio_Click" HorizontalAlignment="Right"/></Grid>
     </Grid>
    </ContentControl>

    <ContentControl x:Name="NotificationsBlockPanel" Grid.Row="2" Grid.Column="2" Style="{StaticResource SteelPanel}" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
     <Grid><Grid.RowDefinitions><RowDefinition Height="45"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions><Grid><TextBlock Text="СПОВІЩЕННЯ" Style="{StaticResource PanelTitle}"/><TextBlock Text="DONATELLO • DISCORD BOT" HorizontalAlignment="Right" Foreground="#88A45D" VerticalAlignment="Center"/></Grid><Border Grid.Row="1" Background="#D9080A06" BorderBrush="#5E5638" BorderThickness="1"><Grid><ItemsControl ItemsSource="{Binding DonationPage}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="10,7"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="85"/></Grid.ColumnDefinitions><TextBlock Text="♥" Foreground="#C99A45"/><TextBlock Grid.Column="1" Text="{Binding User}" FontWeight="Bold"/><TextBlock Grid.Column="2" Text="{Binding EventSummary}"/><TextBlock Grid.Column="3" Text="{Binding DisplayTime}" Foreground="#8A8770"/></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="DonationEmptyStateText" Text="Подій ще немає" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#77745F"/></Grid></Border><Grid Grid.Row="2"><TextBlock x:Name="LastNotificationText" VerticalAlignment="Center"/><TextBlock x:Name="LastNotificationTimeText" HorizontalAlignment="Right" VerticalAlignment="Center"/><Button Content="ВІДКРИТИ ПОВНИЙ ЖУРНАЛ" Click="OpenJournal_Click" HorizontalAlignment="Center"/></Grid></Grid>
    </ContentControl>
   </Grid>

   <Grid Grid.Row="2" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition x:Name="FooterSystemColumn" Width="1.05*"/><ColumnDefinition Width="8"/><ColumnDefinition x:Name="FooterEventsColumn" Width="0.9*"/><ColumnDefinition Width="8"/><ColumnDefinition x:Name="FooterMonitorColumn" Width="1.05*"/></Grid.ColumnDefinitions>
    <ContentControl x:Name="SystemStatusBlockPanel" Grid.Column="0" Style="{StaticResource SteelPanel}" AllowDrop="True"><Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="СТАН СИСТЕМИ" Style="{StaticResource PanelTitle}"/><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="SystemObsText"/><TextBlock x:Name="SystemTwitchText"/><TextBlock x:Name="SystemYouTubeText"/><TextBlock x:Name="SystemOverlayText"/><TextBlock x:Name="SystemDonatelloText"/><TextBlock x:Name="SystemDiscordText"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="СТАН:" Foreground="#8A8770"/><TextBlock x:Name="AllSystemsStatusText" FontWeight="Bold"/><TextBlock x:Name="SystemStateText" TextWrapping="Wrap" Foreground="#AAA68E" Margin="0,8,0,0"/><TextBlock x:Name="LastLogText" TextWrapping="Wrap" Foreground="#77745F" Margin="0,8,0,0"/></StackPanel></Grid></Grid></ContentControl>
    <ContentControl x:Name="ModulesBlockPanel" Grid.Column="2" Style="{StaticResource SteelPanel}" AllowDrop="True"><Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="40"/></Grid.RowDefinitions><Grid Background="#C90C0D09"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="STALKER" FontFamily="Bahnschrift Condensed, Impact" FontSize="52" FontWeight="Black" Foreground="#D7D0B6" HorizontalAlignment="Center" VerticalAlignment="Center"/><TextBlock Grid.Row="1" Text="ЗОНА ЧЕКАЄ НА ТЕБЕ..." FontSize="18" Foreground="#B59452" HorizontalAlignment="Center" Margin="0,0,0,14"/></Grid><UniformGrid Grid.Row="1" Columns="4"><Button Content="ЧАТ-БОТ" Click="OpenChat_Click"/><Button Content="OVERLAY" Click="OpenOverlay_Click"/><Button Content="МУЗИКА" Click="OpenMusic_Click"/><Button Content="СПОВІЩЕННЯ" Click="OpenNotifications_Click"/></UniformGrid></Grid></ContentControl>
    <ContentControl x:Name="SystemMonitorPanel" Grid.Column="4" Style="{StaticResource SteelPanel}" AllowDrop="True"><Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="30"/></Grid.RowDefinitions><Grid><TextBlock Text="МОНІТОРИНГ ПК" Style="{StaticResource PanelTitle}"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Ellipse x:Name="AidaStatusDot" Width="8" Height="8"/><TextBlock x:Name="AidaStatusText" Text="WINDOWS" Margin="5,0"/><TextBlock x:Name="SystemClockText"/></StackPanel></Grid><UniformGrid Grid.Row="1" Columns="4"><Border Style="{StaticResource CyberInnerBorder}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="CPU"/><TextBlock x:Name="CpuLoadMonitorText" Text="— %" FontSize="30"/><TextBlock x:Name="CpuClockMonitorText"/><TextBlock x:Name="CpuTemperatureMonitorText"/></StackPanel></Border><Border Style="{StaticResource CyberInnerBorder}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="GPU"/><TextBlock x:Name="GpuLoadMonitorText" Text="— %" FontSize="30"/><TextBlock x:Name="GpuTemperatureMonitorText"/></StackPanel></Border><Border Style="{StaticResource CyberInnerBorder}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="RAM"/><TextBlock x:Name="RamLoadMonitorText" Text="—" FontSize="24"/><TextBlock x:Name="MemoryClockMonitorText"/><TextBlock x:Name="VramLoadMonitorText"/></StackPanel></Border><Border Style="{StaticResource CyberInnerBorder}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="FPS"/><TextBlock Text="60" FontSize="40" Foreground="#A7C76B"/><TextBlock x:Name="ObsFpsText"/><TextBlock x:Name="UptimeText"/></StackPanel></Border></UniformGrid><TextBlock Grid.Row="2" x:Name="NetworkText" HorizontalAlignment="Center" Foreground="#8A9C66"/></Grid></ContentControl>
   </Grid>

   <Border Grid.Row="3" Background="#E40C0E09" BorderBrush="#5A5134" BorderThickness="1" Margin="4,6,4,0"><Grid Margin="12,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="●  STALKER MODE ACTIVE" Foreground="#8FB25D" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="TiHiY StreamControl Center" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8A8770"/><TextBlock Grid.Column="2" Text="ПОВНИЙ КОНТРОЛЬ ТВОГО СТРІМУ" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8A8770"/><TextBlock Grid.Column="3" Text="20:39:45" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#C8B98A"/></Grid></Border>

   <Grid Visibility="Collapsed">
    <Grid.ColumnDefinitions><ColumnDefinition x:Name="BottomLeftColumn"/><ColumnDefinition x:Name="BottomRightColumn"/></Grid.ColumnDefinitions>
    <Grid.RowDefinitions><RowDefinition x:Name="FooterRow" Height="180"/></Grid.RowDefinitions>
    <Button x:Name="ConnectObsButton" Click="ConnectObs_Click"><TextBlock x:Name="ConnectObsButtonText"/></Button>
    <Button x:Name="LayoutEditButton" Click="ToggleLayoutEdit_Click"/>
   </Grid>
  </Grid>
 </Border>
</Window>