<Window x:Class="TiHiY.StreamControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TiHiY StreamControl Center" Width="1420" Height="850" MinWidth="1080" MinHeight="680"
        Background="#07131E" Foreground="#EDF7FF" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize" BorderBrush="#24465D" BorderThickness="1">
    <Grid Margin="14" Background="#07131E">
        <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="44"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚜" Foreground="{StaticResource Yellow}" FontSize="34" Margin="4,0,14,0"/>
                <TextBlock Text="TiHiY StreamControl Center" FontSize="27" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="12,6" CornerRadius="3" Margin="0,0,12,0"><StackPanel Orientation="Horizontal"><Ellipse Width="14" Height="14" Fill="#1479D1"/><Ellipse Width="14" Height="14" Fill="#FFD329" Margin="-14,7,0,-7"/><TextBlock Text="  TiHiY-DED" FontWeight="SemiBold"/></StackPanel></Border>
                <Button Content="—" Width="42" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="MinimizeWindow_Click"/>
                <Button x:Name="MaximizeButton" Content="□" Width="42" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="MaximizeWindow_Click"/>
                <Button Content="×" Width="42" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="CloseWindow_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,1">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⌂  Головна" Click="Home_Click" Foreground="{StaticResource Blue}"/>
                    <Button Content="💬  Чат" Click="Home_Click"/><Button Content="⚡  Команди" Click="Commands_Click"/>
                    <Button Content="🔔  Алерти" Click="AlertsMenu_Click"/><Button Content="◇  Overlay" Click="OverlayMenu_Click"/>
                    <Button Content="OBS" Click="ObsMenu_Click"/><Button Content="🎁  Донати" Click="DonationsMenu_Click"/><Button Content="⚙  Налаштування" Click="Settings_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="TwitchStatus" Style="{StaticResource StatusButton}" Tag="OFF" Click="ServiceStatus_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="Twitch" Margin="0,0,7,0"/><Ellipse x:Name="TwitchDot" Width="9" Height="9" Fill="#FF3B43" VerticalAlignment="Center"/><TextBlock x:Name="TwitchState" Text=" OFF" Foreground="#FF5960" FontWeight="Bold"/></StackPanel></Button>
                    <Button x:Name="YouTubeStatus" Style="{StaticResource StatusButton}" Tag="OFF" Click="ServiceStatus_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="YouTube" Margin="0,0,7,0"/><Ellipse x:Name="YouTubeDot" Width="9" Height="9" Fill="#FF3B43" VerticalAlignment="Center"/><TextBlock x:Name="YouTubeState" Text=" OFF" Foreground="#FF5960" FontWeight="Bold"/></StackPanel></Button>
                    <Button x:Name="ObsStatus" Style="{StaticResource StatusButton}" Tag="OFF" Click="ServiceStatus_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="OBS" Margin="0,0,7,0"/><Ellipse x:Name="ObsDot" Width="9" Height="9" Fill="#FF3B43" VerticalAlignment="Center"/><TextBlock x:Name="ObsState" Text=" OFF" Foreground="#FF5960" FontWeight="Bold"/></StackPanel></Button>
                    <Button x:Name="DonatelloStatus" Style="{StaticResource StatusButton}" Tag="OFF" Click="ServiceStatus_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="Donatello" Margin="0,0,7,0"/><Ellipse x:Name="DonatelloDot" Width="9" Height="9" Fill="#FF3B43" VerticalAlignment="Center"/><TextBlock x:Name="DonatelloState" Text=" OFF" Foreground="#FF5960" FontWeight="Bold"/></StackPanel></Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,8">
            <Grid x:Name="HomeView">
                <Grid.RowDefinitions><RowDefinition Height="3*"/><RowDefinition Height="2*"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Margin="0,0,8,8" Padding="12">
                    <DockPanel><TextBlock DockPanel.Dock="Top" Text="ОБ’ЄДНАНИЙ ЧАТ" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,10"/>
                        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="MessageInput" KeyDown="MessageInput_KeyDown"/><Button Grid.Column="1" Content="НАДІСЛАТИ" Click="Send_Click" Background="#123B32"/>
                        </Grid>
                        <ListBox x:Name="ChatList" ItemsSource="{Binding Messages}"><ListBox.ItemTemplate><DataTemplate>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="100"/><ColumnDefinition Width="140"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time, StringFormat=HH:mm:ss}" Foreground="#60C8FF"/>
                                <TextBlock Grid.Column="1" Text="{Binding Platform}" Foreground="{Binding Accent}"/>
                                <TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Accent}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="{Binding Text}" TextWrapping="Wrap"/>
                            </Grid></DataTemplate></ListBox.ItemTemplate></ListBox>
                    </DockPanel>
                </Border>
                <Grid Grid.Row="0" Grid.Column="1" Margin="8,0,0,8"><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="12" Margin="0,0,0,6">
                        <StackPanel><TextBlock Text="АЛЕРТИ ТА ДОНАТИ" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="ViperUA — 200 UAH" FontSize="24" Foreground="{StaticResource Green}" Margin="0,18,0,5"/><TextBlock Text="Дякую за контент! Слава Україні! 💙💛" Foreground="{StaticResource Muted}"/></StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="12" Margin="0,6,0,0">
                        <DockPanel><TextBlock DockPanel.Dock="Top" Text="ЖУРНАЛ ПОДІЙ" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/><ListBox ItemsSource="{Binding Events}" Foreground="{StaticResource Muted}"/></DockPanel>
                    </Border>
                </Grid>
                <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Margin="0,8,8,0" Padding="12">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="1.4*"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="СЦЕНИ" FontSize="18" FontWeight="SemiBold"/><ListBox SelectedIndex="0" Margin="0,8,10,0"><ListBoxItem>Main Scene</ListBoxItem><ListBoxItem>BRB Scene</ListBoxItem><ListBoxItem>Starting Soon</ListBoxItem><ListBoxItem>Ending Scene</ListBoxItem><ListBoxItem>Just Chatting</ListBoxItem></ListBox></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="АУДІО МІКШЕР" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="🎙  Мікрофон" Margin="0,15,0,2"/><Slider Value="62" Maximum="100"/><TextBlock Text="🔊  Системний звук" Margin="0,10,0,2"/><Slider Value="48" Maximum="100"/><TextBlock Text="♫  Музика" Margin="0,10,0,2"/><Slider Value="35" Maximum="100"/></StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Margin="8,8,0,0" Padding="28">
                    <StackPanel VerticalAlignment="Center"><Button Content="▶  ПОЧАТИ СТРІМ" FontSize="19" Height="54" Background="#1453A5" Click="StartStream_Click"/><Button Content="■  ЗАВЕРШИТИ СТРІМ" FontSize="19" Height="54" Background="#8B1D25" Click="StopStream_Click"/><Button Content="🎁  ТЕСТОВИЙ ДОНАТ" FontSize="19" Height="54" Background="#C99800" Foreground="Black" Click="TestDonation_Click"/><Button Content="◇  ВІДКРИТИ OVERLAY" Click="Overlay_Click"/></StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="CommandsView" Visibility="Collapsed">
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="16" Margin="0,0,8,0">
                    <DockPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="КОМАНДИ БОТА" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="●  БОТ ПІДКЛЮЧЕНО (демонстраційний режим)" Foreground="{StaticResource Green}" Margin="0,5,0,15"/></StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"><Button Content="+ ДОДАТИ КОМАНДУ" Click="AddCommand_Click"/><Button Content="ІМПОРТ JSON/CSV" Click="ImportCommands_Click"/></StackPanel>
                        <DataGrid x:Name="CommandsGrid" AutoGenerateColumns="False" Background="#081722" Foreground="White" RowBackground="#0B1B29" AlternatingRowBackground="#102638" HeadersVisibility="Column" CanUserAddRows="False" SelectionChanged="CommandsGrid_SelectionChanged">
                            <DataGrid.Columns><DataGridCheckBoxColumn Header="СТАТУС" Binding="{Binding Enabled}"/><DataGridTextColumn Header="КОМАНДА" Binding="{Binding Name}" Width="110"/><DataGridTextColumn Header="ВІДПОВІДЬ" Binding="{Binding Reply}" Width="*"/><DataGridTextColumn Header="ПЛАТФОРМА" Binding="{Binding Platform}" Width="130"/><DataGridTextColumn Header="ЗАТРИМКА" Binding="{Binding CooldownSeconds}" Width="90"/></DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="16" Margin="8,0,0,0">
                    <StackPanel><TextBlock Text="НАЛАШТУВАННЯ КОМАНДИ" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="Команда" Margin="0,18,0,4"/><TextBox x:Name="CommandNameTextBox" Text="!команда"/><TextBlock Text="Відповідь бота" Margin="0,12,0,4"/><TextBox x:Name="CommandReplyTextBox" Text="Відповідь бота" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/><TextBlock Text="Платформа" Margin="0,12,0,4"/><ComboBox x:Name="CommandPlatformCombo" SelectedIndex="0"><ComboBoxItem Content="Twitch + YouTube"/><ComboBoxItem Content="Twitch"/><ComboBoxItem Content="YouTube"/></ComboBox><TextBlock Text="Затримка, секунд" Margin="0,12,0,4"/><TextBox x:Name="CommandCooldownTextBox" Text="10"/><CheckBox x:Name="CommandEnabledCheck" Content="Команда увімкнена" IsChecked="True" Margin="0,12"/><Button Content="ЗБЕРЕГТИ" Background="#1453A5" Margin="3,12,3,3" Click="SaveCommand_Click"/><Button Content="ТЕСТУВАТИ" Click="TestCommand_Click"/><Button Content="ВИДАЛИТИ" Background="#6E1B24" Click="DeleteCommand_Click"/></StackPanel>
                </Border>
            </Grid>

            <Border x:Name="SettingsView" Visibility="Collapsed" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="24">
                <StackPanel Width="620" HorizontalAlignment="Left"><TextBlock Text="НАЛАШТУВАННЯ" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="OBS WebSocket" FontSize="18" Margin="0,20,0,8"/><TextBlock Text="Адреса"/><TextBox x:Name="ObsUrlTextBox" Text="ws://127.0.0.1:4455" Margin="0,4,0,10"/><TextBlock Text="Пароль"/><PasswordBox x:Name="ObsPasswordBox" Background="#081722" Foreground="White" BorderBrush="{StaticResource Line}" Padding="10" Margin="0,4,0,8"/><StackPanel Orientation="Horizontal"><Button Content="ПІДКЛЮЧИТИ OBS" Background="#1453A5" Click="ConnectObs_Click"/><Button Content="ЗБЕРЕГТИ" Click="SaveSettings_Click"/></StackPanel><TextBlock x:Name="ObsConnectionMessage" Text="OBS не підключено" Foreground="#FF5960" Margin="4,4,0,10"/><CheckBox x:Name="TopmostCheck" Content="Головне вікно поверх інших" Margin="0,12,0,10" Click="TopmostCheck_Click"/><CheckBox Content="Запускати разом із Windows" Margin="0,8"/><CheckBox Content="Автоматично відкривати ігровий overlay" Margin="0,8"/><TextBlock Text="Гарячі клавіші overlay" FontSize="18" Margin="0,20,0,8"/><TextBlock Text="Ctrl + Shift + C — показати/приховати   •   Ctrl + Shift + L — режим кліків" Foreground="{StaticResource Muted}"/><TextBlock Text="Twitch, YouTube і Donatello підключимо через окрему безпечну авторизацію." TextWrapping="Wrap" Margin="0,20,0,0" Foreground="{StaticResource Yellow}"/></StackPanel>
            </Border>

            <Border x:Name="ModuleView" Visibility="Collapsed" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="24">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock x:Name="ModuleTitleText" Text="МОДУЛЬ" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="ModuleDescriptionText" Text="Налаштування модуля" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,22"/><CheckBox x:Name="ModuleEnabledCheck" Content="Модуль увімкнений" IsChecked="True" Margin="0,8"/><TextBlock x:Name="ModuleSliderLabel" Text="Гучність / прозорість" Margin="0,18,0,5"/><Slider x:Name="ModuleSlider" Minimum="0" Maximum="100" Value="70" Width="420" HorizontalAlignment="Left"/><StackPanel Orientation="Horizontal" Margin="0,20,0,0"><Button Content="ЗБЕРЕГТИ" Background="#1453A5" Click="SaveModule_Click"/><Button x:Name="ModuleTestButton" Content="ТЕСТУВАТИ" Click="TestModule_Click"/></StackPanel></StackPanel>
                    <Border Grid.Column="1" Background="#081722" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="18" Margin="20,0,0,0"><StackPanel><TextBlock Text="СТАН МОДУЛЯ" FontSize="18" FontWeight="SemiBold"/><TextBlock x:Name="ModuleStateText" Text="● ГОТОВО" Foreground="{StaticResource Green}" FontSize="18" Margin="0,18,0,10"/><TextBlock x:Name="ModuleHintText" Text="Зміни застосовуються локально." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel></Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#081722" BorderBrush="{StaticResource Line}" BorderThickness="1,1,1,0" Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="GlobalConnectionText" Text="●  OFFLINE     DEMO MODE" Foreground="#FF5960" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ЯКІСТЬ: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="QualityText" Text="—" Foreground="{StaticResource Muted}" FontWeight="Bold" Margin="0,0,20,0"/>
                    <TextBlock Text="ЧАС: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="StreamTimeText" Text="00:00:00" FontWeight="SemiBold" Margin="0,0,20,0"/>
                    <TextBlock Text="БІТРЕЙТ: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="BitrateText" Text="0 kb/s" Margin="0,0,20,0"/>
                    <TextBlock Text="FPS: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="FpsText" Text="0" Margin="0,0,20,0"/>
                    <TextBlock Text="ПРОПУЩЕНО: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="DroppedFramesText" Text="0 (0.0%)" Foreground="{StaticResource Green}" Margin="0,0,20,0"/>
                    <TextBlock Text="TWITCH: " Foreground="#A970FF"/><TextBlock x:Name="TwitchLossText" Text="0.0%" Foreground="{StaticResource Green}" Margin="0,0,14,0"/>
                    <TextBlock Text="YOUTUBE: " Foreground="#FF5960"/><TextBlock x:Name="YouTubeLossText" Text="0.0%" Foreground="{StaticResource Green}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="StatusText" Text="TSC v0.4.0" VerticalAlignment="Center" Foreground="#62BDEB" Margin="18,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
