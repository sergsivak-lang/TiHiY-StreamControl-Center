<Window x:Class="TiHiY.StreamControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
        Title="TiHiY StreamControl Center" Width="1480" Height="900" MinWidth="1040" MinHeight="680"
        Icon="/TiHiY.StreamControlCenter;component/Assets/TiHiY.StreamControlCenter.ico"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged">
    <Border BorderBrush="{DynamicResource Amber}" BorderThickness="1" Background="{DynamicResource WindowBackground}">
        <Grid x:Name="DesignSurface" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="68"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="98"/>
            </Grid.RowDefinitions>

            <!-- ==================== CYBER HEADER ==================== -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="4"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="50" Height="50" CornerRadius="25" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" Background="#071B26" Effect="{StaticResource CyanGlow}">
                            <Image Source="/TiHiY.StreamControlCenter;component/Assets/AppLogo.png" Stretch="Uniform" Margin="3"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TiHiY" FontSize="25" FontStyle="Italic" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                                <TextBlock Text="  StreamControl" FontSize="25" FontStyle="Italic" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <TextBlock Text=" Center" FontSize="25" FontStyle="Italic" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                            </StackPanel>
                            <TextBlock Text="MULTICHAT  •  DONATIONS  •  OBS AUDIO  •  MUSIC" FontSize="10" Foreground="{DynamicResource Muted}" Margin="1,-1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,14,0">
                        <TextBlock Text="МАСШТАБ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <Button Style="{StaticResource TitleButton}" Content="−" Click="ZoomOut_Click"/>
                        <Button x:Name="ZoomTextButton" Style="{StaticResource TitleButton}" Content="АВТО" MinWidth="90" Width="Auto" Padding="10,0" Click="ZoomAuto_Click"/>
                        <Button Style="{StaticResource TitleButton}" Content="+" Click="ZoomIn_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource TitleButton}" Content="—" Click="Minimize_Click"/>
                        <Button Style="{StaticResource TitleButton}" Content="□" Click="Maximize_Click"/>
                        <Button Style="{StaticResource CloseTitleButton}" Content="×" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== STATUS / ACTION BAR ==================== -->
            <Border Grid.Row="1" Background="#041019" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="4" Margin="0,6,0,0">
                <Grid Margin="10,6">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusChip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE7F8;" Foreground="{DynamicResource Cyan}" Margin="0,0,7,0"/>
                                <Ellipse x:Name="ObsDot" Width="9" Height="9" Fill="{DynamicResource Red}" Margin="0,0,7,0"/>
                                <TextBlock Text="OBS AUDIO" FontWeight="Bold"/>
                                <TextBlock x:Name="ObsStatusText" Text="  ВІДКЛЮЧЕНО" Foreground="{DynamicResource Red}" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusChip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE895;" Foreground="{DynamicResource Amber}" Margin="0,0,7,0"/>
                                <Ellipse Width="9" Height="9" Fill="{DynamicResource Yellow}" Margin="0,0,7,0"/>
                                <TextBlock Text="MULTISTREAM" FontWeight="Bold"/>
                                <TextBlock x:Name="BridgeStatusText" Text="  НЕ ПЕРЕВІРЕНО" Foreground="{DynamicResource Yellow}" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusChip}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" Background="#9147FF" CornerRadius="3"><TextBlock Text="T" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <TextBlock Text=" TWITCH: " Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TwitchTopStatusText" Text="OFF" Foreground="#B37AFF" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Width="22" Height="22" Background="#E71928" CornerRadius="3" Margin="14,0,0,0"><TextBlock Text="▶" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <TextBlock Text=" YOUTUBE: " Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="YouTubeTopStatusText" Text="OFF" Foreground="#FF5965" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource BlueButton}" Click="ConnectObs_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE71B;" FontSize="16" Margin="0,0,8,0"/><TextBlock Text="ПІДКЛЮЧИТИ OBS"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource PurpleButton}" Click="OpenChannels_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE716;" FontSize="16" Margin="0,0,8,0"/><TextBlock Text="КАНАЛИ"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RedButton}" Click="OpenYouTubeSettings_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="▶" FontSize="12" Margin="0,0,8,0"/><TextBlock Text="YOUTUBE ТРАНСЛЯЦІЯ"/></StackPanel>
                        </Button>
                        <Button Click="OpenSettings_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE713;" FontSize="16" Margin="0,0,8,0"/><TextBlock Text="НАЛАШТУВАННЯ"/></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== DASHBOARD ==================== -->
            <Grid Grid.Row="2" Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="MainLeftColumn" Width="1.18*" MinWidth="500"/>
                    <ColumnDefinition Width="7"/>
                    <ColumnDefinition x:Name="MainRightColumn" Width="1*" MinWidth="410"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="MainTopRow" Height="1.45*" MinHeight="320"/>
                    <RowDefinition Height="7"/>
                    <RowDefinition x:Name="MainBottomRow" Height="1*" MinHeight="245"/>
                </Grid.RowDefinitions>

                <!-- MULTICHAT -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}" BorderBrush="{DynamicResource Cyan}" Margin="0,0,4,4">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition/><RowDefinition Height="54"/></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="МУЛЬТИЧАТ  •  TWITCH + YOUTUBE" Style="{StaticResource CyberHeaderText}"/>
                                <TextBlock x:Name="ChatStatusText" Text="Підключіть канали для реального чату" Foreground="{DynamicResource Muted}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#25133D" BorderBrush="#9A54FF" BorderThickness="1" CornerRadius="3" Padding="9,6" Margin="3">
                                    <StackPanel Orientation="Horizontal"><Border Width="22" Height="22" Background="#9147FF" CornerRadius="3"><TextBlock Text="T" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="  ◉ " Foreground="#CBAAFF" VerticalAlignment="Center"/><TextBlock x:Name="TwitchViewerText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock x:Name="TwitchLiveText" Text="  OFF" Foreground="{DynamicResource Muted}" FontWeight="Bold" VerticalAlignment="Center"/></StackPanel>
                                </Border>
                                <Border Background="#371216" BorderBrush="#FF3848" BorderThickness="1" CornerRadius="3" Padding="9,6" Margin="3">
                                    <StackPanel Orientation="Horizontal"><Border Width="22" Height="22" Background="#E71928" CornerRadius="3"><TextBlock Text="▶" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="  ◉ " Foreground="#FF7D86" VerticalAlignment="Center"/><TextBlock x:Name="YouTubeViewerText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Text="  ♡ " Foreground="#FF7D86" VerticalAlignment="Center"/><TextBlock x:Name="YouTubeLikesText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock x:Name="YouTubeLiveText" Text="  OFF" Foreground="{DynamicResource Muted}" FontWeight="Bold" VerticalAlignment="Center"/></StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Style="{StaticResource CyberInnerBorder}" BorderBrush="#17617B" Padding="6">
                            <ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}" Background="Transparent" BorderThickness="0" Padding="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Мут на 10 хвилин" Click="MuteChatUser_Click" Tag="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Забанити" Click="BanChatUser_Click" Tag="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Видалити повідомлення" Click="DeleteChatMessage_Click" Tag="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ChatMessage}">
                                        <Border Background="{Binding Background}" CornerRadius="2" Padding="6,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="68"/><ColumnDefinition Width="30"/><ColumnDefinition Width="150"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayTime}" Foreground="#7595A5" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Width="22" Height="22" Background="{Binding PlatformColor}" CornerRadius="3" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding PlatformIcon}" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,4,0" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Text}" Foreground="{Binding Foreground}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="ChatInput" KeyDown="ChatInput_KeyDown" VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource PurpleButton}" Click="SendTwitch_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="T" FontWeight="Black" Margin="0,0,7,0"/><TextBlock Text="TWITCH"/></StackPanel></Button>
                                <Button Style="{StaticResource RedButton}" Click="SendYouTube_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="▶" Margin="0,0,7,0"/><TextBlock Text="YOUTUBE"/></StackPanel></Button>
                                <Button Style="{StaticResource BlueButton}" Click="SendBoth_Click"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE122;" Margin="0,0,7,0"/><TextBlock Text="В ОБИДВА"/></StackPanel></Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- QUICK MIXER -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelBorder}" BorderBrush="{DynamicResource Amber}" Margin="4,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition/><RowDefinition Height="52"/></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="ШВИДКИЙ МІКШЕР  •  AUDIO MIXER OBS" Style="{StaticResource CyberHeaderText}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock x:Name="AudioPageText" Text="1 / 1" Foreground="{DynamicResource Muted}"/><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE713;" Foreground="{DynamicResource Muted}" Margin="12,0,0,0"/></StackPanel>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding QuickAudioPage}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="4" Columns="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AudioChannel}">
                                    <Border Background="#06141D" BorderBrush="#1A4B5D" BorderThickness="1" CornerRadius="3" Margin="0,3" Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="155"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="34" Height="34" Background="#1E1503" BorderBrush="{DynamicResource Amber}" BorderThickness="1" CornerRadius="3">
                                                    <TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE720;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Margin="9,0,0,0" VerticalAlignment="Center"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding DbText}" Foreground="{DynamicResource Amber}" FontSize="10"/></StackPanel>
                                            </StackPanel>
                                            <Grid Grid.Column="1" Margin="8,0">
                                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                                <ProgressBar Value="{Binding Meter}" Maximum="1" Height="7" VerticalAlignment="Center">
                                                    <ProgressBar.Foreground>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#16E36F" Offset="0"/><GradientStop Color="#D6E315" Offset="0.65"/><GradientStop Color="#FF8A00" Offset="1"/></LinearGradientBrush>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                                <Slider Grid.Row="1" Value="{Binding Volume}" Minimum="0" Maximum="1" Tag="{Binding}" ValueChanged="QuickVolumeSlider_ValueChanged"/>
                                            </Grid>
                                            <Button Grid.Column="2" Style="{StaticResource AmberButton}" Content="{Binding MuteText}" Tag="{Binding}" Click="QuickMute_Click" MinWidth="78"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"><Button Style="{StaticResource TitleButton}" Content="‹" Click="PreviousAudioPage_Click"/><Button Style="{StaticResource TitleButton}" Content="›" Click="NextAudioPage_Click"/></StackPanel>
                            <TextBlock Grid.Column="1" x:Name="AudioStatusText" Text="OBS не підключено" Foreground="{DynamicResource Green}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource AmberButton}" Click="OpenAudio_Click"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE9D9;" Margin="0,0,8,0"/><TextBlock Text="ВІДКРИТИ ПОВНИЙ МІКШЕР"/></StackPanel></Button>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="7"/>
                <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Height="7"/>

                <!-- DONATIONS -->
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelBorder}" BorderBrush="{DynamicResource Amber}" Margin="0,4,4,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="82"/><RowDefinition/><RowDefinition Height="46"/></Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="ДОНАТИ ТА СПОВІЩЕННЯ" Style="{StaticResource CyberHeaderText}"/>
                            <TextBlock x:Name="DonatelloStatusText" Text="DONATELLO: OFF • SUPER CHAT • BITS" HorizontalAlignment="Right" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Grid.Row="1" Background="#081A1A" BorderBrush="#2D7951" BorderThickness="1" CornerRadius="3" Padding="11">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" Background="#2B1B02" BorderBrush="{DynamicResource Amber}" BorderThickness="1" CornerRadius="4" Effect="{StaticResource AmberGlow}"><TextBlock Text="$" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Amber}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <StackPanel Margin="10,0,0,0"><TextBlock Text="ОСТАННІЙ ДОНАТ" Foreground="{DynamicResource Muted}" FontWeight="Bold"/><TextBlock x:Name="LastDonationAmountText" Text="—" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Amber}"/></StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock x:Name="LastDonationUserText" Text="Донати ще не отримано" FontSize="16" FontWeight="Bold"/><TextBlock x:Name="LastDonationMessageText" Text="Super Chat, Super Sticker, Bits і підписки з’являються автоматично." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel>
                                <TextBlock Grid.Column="2" Text="●" Foreground="{DynamicResource Amber}" VerticalAlignment="Top" FontSize="13"/>
                            </Grid>
                        </Border>

                        <ItemsControl Grid.Row="2" ItemsSource="{Binding DonationPage}" Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2" Rows="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DonationEvent}">
                                    <Border Background="#06151F" BorderBrush="#1A4C5D" BorderThickness="1" CornerRadius="3" Margin="3" Padding="8">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding User}" FontWeight="Bold" Foreground="{Binding Accent}"/><TextBlock Text="{Binding Message}" Foreground="{DynamicResource Muted}" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="{Binding DisplayAmount}" FontWeight="Bold" Foreground="{Binding Accent}" HorizontalAlignment="Right"/><TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource Muted}" HorizontalAlignment="Right"/></StackPanel></Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="3" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="ЦІЛЬ ЗБОРУ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="DonationGoalProgress" Grid.Column="1" Minimum="0" Maximum="1" Height="12" Margin="12,0" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource AmberButton}" Click="TestDonation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="$" FontWeight="Bold" Margin="0,0,7,0"/><TextBlock Text="ТЕСТОВИЙ ДОНАТ"/></StackPanel></Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- MODULES -->
                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PanelBorder}" BorderBrush="{DynamicResource Cyan}" Margin="4,4,0,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="МОДУЛІ" Style="{StaticResource CyberHeaderText}"/>
                        <UniformGrid Grid.Row="1" Columns="3" Rows="4" Margin="0,2,0,0">
                            <Button Style="{StaticResource ModuleButton}" Click="OpenChat_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE8BD;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="ЧАТ І БОТ" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenOverlay_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE7F8;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="OVERLAY OBS" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenMusic_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE8D6;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="МУЗИКА&#10;NOW PLAYING" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenAudio_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE9D9;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="ПОВНИЙ&#10;АУДІОМІКШЕР" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenChannels_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE716;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="КАНАЛИ&#10;ТА DISCORD" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenNotifications_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Amber}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xEA8F;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="СПОВІЩЕННЯ&#10;DISCORD BOT" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenYouTubeSettings_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="#FF3848" BorderThickness="1" CornerRadius="3"><TextBlock Text="▶" Foreground="#FF3848" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="YOUTUBE&#10;STUDIO" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource AmberModuleButton}" Click="OpenDonatello_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Amber}" BorderThickness="1" CornerRadius="3"><TextBlock Text="$" Foreground="{DynamicResource Amber}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="DONATELLO&#10;ДОНАТИ" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenSettings_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE713;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="НАЛАШТУВАННЯ" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                            <Button Style="{StaticResource ModuleButton}" Click="OpenJournal_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="32" Height="32" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE8A5;" Foreground="{DynamicResource Amber}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" Text="ЖУРНАЛ&#10;ПОДІЙ" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/></Grid></Button>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== FOOTER ==================== -->
            <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Padding="12" BorderBrush="{DynamicResource Line}" Effect="{x:Null}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE950;" Foreground="{DynamicResource Cyan}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="СТАН СИСТЕМИ" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><TextBlock x:Name="SystemStateText" Text="Очікування підключення OBS" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/></StackPanel>
                    </Grid>
                    <Grid Grid.Column="1" Margin="16,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" BorderBrush="{DynamicResource Cyan}" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE823;" Foreground="{DynamicResource Cyan}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="ОСТАННЯ ПОДІЯ" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><TextBlock x:Name="LastLogText" Text="TiHiY StreamControl Center готовий" Foreground="{DynamicResource Muted}" TextTrimming="CharacterEllipsis"/></StackPanel>
                    </Grid>
                    <Button Grid.Column="2" Style="{StaticResource AmberButton}" Click="OpenJournal_Click" VerticalAlignment="Center"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="{DynamicResource IconFont}" Text="&#xE8A5;" Margin="0,0,8,0"/><TextBlock Text="ВІДКРИТИ ЖУРНАЛ"/></StackPanel></Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
