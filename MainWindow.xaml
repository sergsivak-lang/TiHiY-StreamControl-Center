<Window x:Class="TiHiY.StreamControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
        Title="TiHiY StreamControl Center — Cyber Amber"
        Width="1680" Height="940" MinWidth="1120" MinHeight="700"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Cyan}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>
        <Style x:Key="TinyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="10.5"/>
        </Style>
        <Style x:Key="IconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource Amber}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <DataTemplate x:Key="ModuleContentTemplate">
            <Grid Margin="2">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}"
                           Style="{StaticResource IconGlyph}" FontSize="24"/>
                <TextBlock Grid.Row="1" Text="{Binding}" TextAlignment="Center" TextWrapping="Wrap"
                           FontWeight="Bold" FontSize="10.5" Foreground="{StaticResource Text}" Margin="2,4,2,0"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource WindowGradient}" BorderBrush="#2B829A" BorderThickness="1">
        <Grid>
            <!-- Subtle vector circuit backdrop: decorative only, never a stretched image. -->
            <Viewbox Stretch="Fill" Opacity="0.075" IsHitTestVisible="False">
                <Canvas Width="1680" Height="940">
                    <Path Stroke="#2BD8FF" StrokeThickness="2" Data="M20,170 H210 V120 H410 M70,620 H270 V700 H480 M1320,125 H1480 V205 H1640 M1180,760 H1390 V690 H1640"/>
                    <Path Stroke="#FF9F19" StrokeThickness="2" Data="M15,360 H130 V300 H250 M1440,400 H1560 V330 H1660 M1110,900 V830 H1270 V790"/>
                    <Path Stroke="#2BD8FF" StrokeThickness="1" Data="M300,40 V110 H520 V70 M720,15 V95 H900 M980,55 H1130 V20 M390,910 V840 H610 V890 M870,920 V860 H1010"/>
                    <Ellipse Canvas.Left="205" Canvas.Top="114" Width="12" Height="12" Stroke="#2BD8FF" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="1468" Canvas.Top="195" Width="12" Height="12" Stroke="#FF9F19" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="1255" Canvas.Top="782" Width="12" Height="12" Stroke="#2BD8FF" StrokeThickness="2"/>
                </Canvas>
            </Viewbox>

            <Grid x:Name="DesignSurface" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="58"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="96"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="7,0,0,0">
                        <Grid Width="48" Height="48">
                            <Ellipse Fill="#071D28" Stroke="{StaticResource Amber}" StrokeThickness="2" Effect="{StaticResource AmberGlow}"/>
                            <Ellipse Margin="4" Stroke="{StaticResource Cyan}" StrokeThickness="1.1"/>
                            <Image Source="Assets/AppIcon.png" Width="38" Height="38" Stretch="Uniform"/>
                        </Grid>
                        <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TiHiY" FontSize="25" FontWeight="Black" Foreground="{StaticResource Cyan}"/>
                                <TextBlock Text="  STREAMCONTROL CENTER" FontSize="25" FontWeight="Bold" Foreground="{StaticResource Amber}"/>
                            </StackPanel>
                            <TextBlock Text="MULTICHAT  •  DONATIONS  •  OBS AUDIO  •  MUSIC" Foreground="{StaticResource Muted}" FontSize="10.5" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="МАСШТАБ" Foreground="{StaticResource Muted}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="−" Width="34" Height="30" MinHeight="0" Padding="0" Click="ZoomOut_Click"/>
                        <Button x:Name="ZoomTextButton" Content="АВТО 98%" MinWidth="86" Height="30" MinHeight="0" Padding="7,0" Click="ZoomAuto_Click" Style="{StaticResource AmberButton}"/>
                        <Button Content="+" Width="34" Height="30" MinHeight="0" Padding="0" Click="ZoomIn_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/>
                        <Button Style="{StaticResource DangerButton}" Content="×" Width="38" Height="30" MinHeight="0" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Connection status and primary actions -->
                <Grid Grid.Row="1" Margin="0,3,0,7">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusPill}">
                            <StackPanel Orientation="Horizontal"><Ellipse x:Name="ObsDot" Width="9" Height="9" Fill="{StaticResource Red}" Margin="0,0,7,0"/><TextBlock Text="OBS AUDIO" FontWeight="Bold"/><TextBlock x:Name="ObsStatusText" Text="  ВІДКЛЮЧЕНО" Foreground="{StaticResource Red}" FontWeight="Bold"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusPill}">
                            <StackPanel Orientation="Horizontal"><Ellipse Width="9" Height="9" Fill="{StaticResource Yellow}" Margin="0,0,7,0"/><TextBlock Text="MULTISTREAM" FontWeight="Bold"/><TextBlock x:Name="BridgeStatusText" Text="  НЕ ПЕРЕВІРЕНО" Foreground="{StaticResource Yellow}" FontWeight="Bold"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusPill}" BorderBrush="#7047B9">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="T" Width="20" Height="20" TextAlignment="Center" Background="#9147FF" Foreground="White" FontWeight="Black"/><TextBlock Text="  TWITCH: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="TwitchTopStatusText" Text="OFF" Foreground="#B98AFF" FontWeight="Bold"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusPill}" BorderBrush="#A8333A">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="▶" Width="22" Height="20" TextAlignment="Center" Background="#E3202A" Foreground="White" FontWeight="Black"/><TextBlock Text="  YOUTUBE: " Foreground="{StaticResource Muted}"/><TextBlock x:Name="YouTubeTopStatusText" Text="OFF" Foreground="#FF6868" FontWeight="Bold"/></StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Click="ConnectObs_Click" MinWidth="155">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE703;" FontSize="17"/><TextBlock Text="  ПІДКЛЮЧИТИ OBS"/></StackPanel>
                        </Button>
                        <Button Click="OpenChannels_Click" MinWidth="120">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE716;" FontSize="17"/><TextBlock Text="  КАНАЛИ"/></StackPanel>
                        </Button>
                        <Button Click="OpenYouTubeSettings_Click" MinWidth="185" BorderBrush="#D24048" Background="#301116">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="▶" Foreground="#FF4048" FontSize="16"/><TextBlock Text="  YOUTUBE ТРАНСЛЯЦІЯ"/></StackPanel>
                        </Button>
                        <Button Click="OpenSettings_Click" MinWidth="145">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE713;" FontSize="17"/><TextBlock Text="  НАЛАШТУВАННЯ"/></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Dashboard -->
                <Grid Grid.Row="2" Margin="0,0,0,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MainLeftColumn" Width="1.38*" MinWidth="540"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition x:Name="MainRightColumn" Width="1*" MinWidth="410"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="MainTopRow" Height="1.23*" MinHeight="330"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition x:Name="MainBottomRow" Height="1*" MinHeight="270"/>
                    </Grid.RowDefinitions>

                    <GridSplitter Grid.Column="1" Grid.RowSpan="3" HorizontalAlignment="Stretch" Background="#143F4E" ShowsPreview="True"/>
                    <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" VerticalAlignment="Stretch" Background="#143F4E" ShowsPreview="True"/>

                    <!-- Multichat -->
                    <ContentControl Grid.Row="0" Grid.Column="0" Style="{StaticResource HudPanel}" Margin="0,0,5,5">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition/><RowDefinition Height="78"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="МУЛЬТИЧАТ • TWITCH + YOUTUBE" Style="{StaticResource HeaderText}"/>
                                    <TextBlock x:Name="ChatStatusText" Text="Підключіть канали для реального чату" Style="{StaticResource TinyLabel}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#281537" BorderBrush="#9254E9" BorderThickness="1" CornerRadius="4" Padding="7,4" Margin="3">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="T" Width="20" Height="20" Background="#9147FF" TextAlignment="Center" FontWeight="Black"/><TextBlock Text="  👁 " VerticalAlignment="Center"/><TextBlock x:Name="TwitchViewerText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock x:Name="TwitchLiveText" Text="  OFF" Foreground="{StaticResource Muted}" FontWeight="Bold" VerticalAlignment="Center"/></StackPanel>
                                    </Border>
                                    <Border Background="#321216" BorderBrush="#D44349" BorderThickness="1" CornerRadius="4" Padding="7,4" Margin="3">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="▶" Width="22" Height="20" Background="#E40010" TextAlignment="Center" FontWeight="Black"/><TextBlock Text="  👁 " VerticalAlignment="Center"/><TextBlock x:Name="YouTubeViewerText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Text="  👍 " VerticalAlignment="Center"/><TextBlock x:Name="YouTubeLikesText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock x:Name="YouTubeLiveText" Text="  OFF" Foreground="{StaticResource Muted}" FontWeight="Bold" VerticalAlignment="Center"/></StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="#02090E" BorderBrush="#19586C" BorderThickness="1" CornerRadius="5" Padding="6">
                                <ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                                            <Border Background="{Binding Background}" CornerRadius="3" Padding="5,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="67"/><ColumnDefinition Width="28"/><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayTime}" Foreground="#748E9A" FontFamily="Consolas" FontSize="11"/>
                                                    <Border Grid.Column="1" Width="20" Height="20" CornerRadius="3" Background="{Binding PlatformColor}" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding PlatformIcon}" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="2,0,8,0"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{StaticResource Text}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="Мут на 10 хвилин" Click="MuteChatUser_Click" Tag="{Binding}"/>
                                                        <MenuItem Header="Забанити користувача" Click="BanChatUser_Click" Tag="{Binding}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Видалити повідомлення" Click="DeleteChatMessage_Click" Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>

                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="36"/></Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="ChatInput" KeyDown="ChatInput_KeyDown" ToolTip="Напишіть повідомлення"/>
                                    <Button Grid.Column="1" Content="➤" FontSize="17" Padding="0" Click="SendBoth_Click" Style="{StaticResource AmberButton}"/>
                                </Grid>
                                <UniformGrid Grid.Row="1" Columns="3" Margin="0,4,0,0">
                                    <Button Click="SendTwitch_Click" BorderBrush="#8350C2" Background="#281238"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="T" Background="#9147FF" Padding="4,1" FontWeight="Black"/><TextBlock Text="  TWITCH"/></StackPanel></Button>
                                    <Button Click="SendYouTube_Click" BorderBrush="#C2353D" Background="#301116"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="▶" Foreground="#FF4048"/><TextBlock Text="  YOUTUBE"/></StackPanel></Button>
                                    <Button Click="SendBoth_Click"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8A7;" FontSize="15"/><TextBlock Text="  В ОБИДВА"/></StackPanel></Button>
                                </UniformGrid>
                            </Grid>
                        </Grid>
                    </ContentControl>

                    <!-- Quick mixer -->
                    <ContentControl Grid.Row="0" Grid.Column="2" Style="{StaticResource HudPanel}" Margin="5,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition/><RowDefinition Height="54"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ШВИДКИЙ МІКШЕР • AUDIO MIXER OBS" Style="{StaticResource HeaderText}"/>
                                    <TextBlock x:Name="AudioStatusText" Text="Підключіть OBS Audio" Style="{StaticResource TinyLabel}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="AudioPageText" Text="1 / 1" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Content="⚙" Width="34" Height="30" MinHeight="0" Padding="0" Click="OpenAudio_Click"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding QuickAudioPage}" VerticalAlignment="Stretch">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:AudioChannel}">
                                        <Border Background="#06151E" BorderBrush="#164557" BorderThickness="1" CornerRadius="4" Margin="0,3" Padding="7,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/><ColumnDefinition Width="124"/><ColumnDefinition Width="*"/><ColumnDefinition Width="82"/><ColumnDefinition Width="43"/><ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE720;" FontSize="17"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="5,0"/>
                                                <Grid Grid.Column="2" Margin="4,0,8,0" VerticalAlignment="Center">
                                                    <ProgressBar Value="{Binding Meter}" Maximum="1" Height="9"/>
                                                    <Grid IsHitTestVisible="False" Opacity="0.38">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="1" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="2" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="3" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="4" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="5" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="6" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="7" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="8" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="9" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="10" BorderBrush="#03070A" BorderThickness="1,0,0,0"/><Border Grid.Column="11" BorderBrush="#03070A" BorderThickness="1,0,0,0"/>
                                                    </Grid>
                                                </Grid>
                                                <Slider Grid.Column="3" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Tag="{Binding}" ValueChanged="QuickVolumeSlider_ValueChanged"/>
                                                <TextBlock Grid.Column="4" Text="{Binding DbText}" Foreground="{StaticResource Amber}" FontFamily="Consolas" FontSize="10.5" VerticalAlignment="Center" TextAlignment="Right"/>
                                                <Button Grid.Column="5" Tag="{Binding}" Click="QuickMute_Click" Content="🔇" Width="32" Height="28" MinHeight="0" Padding="0" ToolTip="{Binding MuteText}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Background" Value="#081923"/><Setter Property="BorderBrush" Value="#25586A"/>
                                                            <Style.Triggers><DataTrigger Binding="{Binding IsMuted}" Value="True"><Setter Property="Background" Value="#42131A"/><Setter Property="BorderBrush" Value="{StaticResource Red}"/></DataTrigger></Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Grid.Row="2" Margin="0,7,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="42"/><ColumnDefinition/><ColumnDefinition Width="210"/></Grid.ColumnDefinitions>
                                <Button Content="◀" Click="PreviousAudioPage_Click" Padding="0"/>
                                <Button Grid.Column="1" Content="▶" Click="NextAudioPage_Click" Padding="0"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><Ellipse Width="9" Height="9" Fill="{StaticResource Green}"/><TextBlock Text="  OBS підключено" Foreground="{StaticResource Green}" FontWeight="SemiBold"/></StackPanel>
                                <Button Grid.Column="3" Click="OpenAudio_Click"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE9E9;" FontSize="16"/><TextBlock Text="  ВІДКРИТИ ПОВНИЙ МІКШЕР"/></StackPanel></Button>
                            </Grid>
                        </Grid>
                    </ContentControl>

                    <!-- Donations and monetization -->
                    <ContentControl Grid.Row="2" Grid.Column="0" Style="{StaticResource HudPanel}" Margin="0,5,5,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="70"/><RowDefinition Height="62"/><RowDefinition Height="54"/></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="ДОНАТИ ТА СПОВІЩЕННЯ" Style="{StaticResource HeaderText}"/>
                                <TextBlock x:Name="DonatelloStatusText" Grid.Column="1" Text="DONATELLO: НЕ ПІДКЛЮЧЕНО • SUPER CHAT • BITS" Foreground="{StaticResource Muted}" FontSize="10.5" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Grid.Row="1" Background="#07161E" BorderBrush="#724D12" BorderThickness="1" CornerRadius="4" Padding="9" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="145"/><ColumnDefinition Width="95"/><ColumnDefinition/><ColumnDefinition Width="76"/></Grid.ColumnDefinitions>
                                    <Grid Width="34" Height="34" VerticalAlignment="Center"><Ellipse Fill="#52340B" Stroke="{StaticResource Amber}" StrokeThickness="1.5"/><TextBlock Text="₴" Foreground="{StaticResource Amber}" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="ОСТАННІЙ ДОНАТ" Foreground="{StaticResource Amber}" FontWeight="Bold"/><TextBlock x:Name="LastDonationUserText" Text="Донати ще не отримано" Foreground="{StaticResource Muted}" FontSize="10.5" TextTrimming="CharacterEllipsis"/></StackPanel>
                                    <TextBlock Grid.Column="2" x:Name="LastDonationAmountText" Text="—" Foreground="{StaticResource Amber}" FontSize="17" FontWeight="Black" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" x:Name="LastDonationMessageText" Text="Donatello, Super Chat, Bits і підписки з’являться тут автоматично." TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="4" Text="LIVE" Foreground="{StaticResource Green}" FontFamily="Consolas" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Background="#06151E" BorderBrush="#18566A" BorderThickness="1" CornerRadius="4" Padding="9" Margin="0,3,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="145"/><ColumnDefinition/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE7ED;" FontSize="21"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="СПОВІЩЕННЯ" Foreground="{StaticResource Cyan}" FontWeight="Bold"/><TextBlock Text="TWITCH • YOUTUBE • DISCORD" Foreground="{StaticResource Muted}" FontSize="9.5"/></StackPanel>
                                    <TextBlock Grid.Column="2" Text="Нові підписки, Super Chat, Bits і донати бот надсилатиме у вибраний канал." TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0"/>
                                    <Button Grid.Column="3" Content="DONATELLO" Click="OpenDonatello_Click" Padding="6"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition/><ColumnDefinition Width="150"/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
                                <TextBlock Text="ЦІЛЬ ЗБОРУ" Foreground="{StaticResource Amber}" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="DonationGoalProgress" Grid.Column="1" Minimum="0" Maximum="100" Value="0" Height="13" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBlock Grid.Column="2" Text="ПРОГРЕС ЗБОРУ" Foreground="{StaticResource Muted}" VerticalAlignment="Center" TextAlignment="Center"/>
                                <Button Grid.Column="3" Style="{StaticResource AmberButton}" Click="TestDonation_Click"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="₴" Foreground="{StaticResource Amber}" FontWeight="Black"/><TextBlock Text="  ТЕСТОВИЙ ДОНАТ"/></StackPanel></Button>
                            </Grid>
                        </Grid>
                    </ContentControl>

                    <!-- Modules -->
                    <ContentControl Grid.Row="2" Grid.Column="2" Style="{StaticResource HudPanel}" Margin="5,5,0,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition/></Grid.RowDefinitions>
                            <TextBlock Text="МОДУЛІ" Style="{StaticResource HeaderText}"/>
                            <UniformGrid Grid.Row="1" Columns="3" Rows="4" Margin="-4,2,-4,-4">
                                <Button Style="{StaticResource ModuleButton}" Click="OpenChat_Click" Tag="&#xE8BD;" Content="ЧАТ І БОТ" ContentTemplate="{StaticResource ModuleContentTemplate}"/>
                                <Button Style="{StaticResource ModuleButton}" Click="OpenOverlay_Click" Tag="&#xE7F4;" Content="OVERLAY OBS + НАД ГРОЮ" ContentTemplate="{StaticResource ModuleContentTemplate}"/>
