<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.StreamNotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        xmlns:ui="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="TiHiY Stream Notify Bot" Width="1240" Height="800" MinWidth="980" MinHeight="650"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource AppWindowFrame}">
        <Grid Background="{DynamicResource AppBackgroundBrush}">
            <Rectangle Fill="{DynamicResource CircuitBackdropBrush}" IsHitTestVisible="False"/>
        <Grid x:Name="DesignSurface" Margin="10">
            <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition/><RowDefinition Height="48"/></Grid.RowDefinitions>

            <Border Style="{StaticResource TitleBarBorder}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Green}" BorderThickness="1">
                            <TextBlock Text="N" Foreground="{DynamicResource Green}" FontSize="20" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="TIHIY STREAM NOTIFY BOT" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                            <TextBlock Text="Окремі Discord-канали: трансляції та монетизація" FontSize="11" Foreground="{DynamicResource Muted}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="&#xE921;" Width="40" Padding="0" Click="Minimize_Click" Style="{StaticResource WindowControlButton}"/>
                        <Button Content="&#xE922;" Width="40" Padding="0" Click="Maximize_Click" Style="{StaticResource WindowControlButton}"/>
                        <Button Content="&#xE8BB;" Width="40" Padding="0" Background="{DynamicResource CloseBg}" Click="Close_Click" Style="{StaticResource WindowControlButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*" MinWidth="500"/><ColumnDefinition Width="7"/><ColumnDefinition Width="*" MinWidth="390"/></Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="DISCORD BOT" FontSize="18" FontWeight="Bold" Foreground="#6F83FF"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0"><TextBlock Text="Application ID" Foreground="{DynamicResource Muted}"/><TextBox x:Name="ApplicationIdBox" Margin="0,4,0,0"/></StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Bot Token (порожньо = не змінювати)" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="BotTokenBox" Margin="0,4,0,0"/></StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource PanelDark}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="КАНАЛИ ПОЧАТКУ ТРАНСЛЯЦІЙ" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                                    <TextBlock Text="ID каналів — через кому або з нового рядка" Foreground="{DynamicResource Muted}" Margin="0,7,0,0"/>
                                    <TextBox x:Name="ChannelIdsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="48" Margin="0,4,0,0"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Згадування" Foreground="{DynamicResource Muted}"/><TextBox x:Name="MentionBox" Margin="0,4,0,0" ToolTip="@everyone, @here, &lt;@&amp;ID_РОЛІ&gt; або порожньо"/></StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Шаблон" Foreground="{DynamicResource Muted}"/><TextBox x:Name="TemplateBox" AcceptsReturn="True" TextWrapping="Wrap" Height="68" Margin="0,4,0,0"/></StackPanel>
                                    </Grid>
                                    <WrapPanel Margin="0,8,0,0">
                                        <CheckBox x:Name="EnabledCheck" Content="Увімкнути сповіщення про старт"/>
                                        <CheckBox x:Name="AutoStartCheck" Content="Автозапуск бота" Margin="18,3,3,3"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,5,0,0">
                                        <CheckBox x:Name="TwitchCheck" Content="TWITCH" FontWeight="Bold" Foreground="#C6A6FF"/>
                                        <TextBlock x:Name="TwitchStateText" Text="  не підключено" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,18,0"/>
                                        <CheckBox x:Name="YouTubeCheck" Content="YOUTUBE" FontWeight="Bold" Foreground="#FF7A7A"/>
                                        <TextBlock x:Name="YouTubeStateText" Text="  не підключено" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource AccentSoft}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="ОКРЕМИЙ КАНАЛ ДОНАТІВ І ПЛАТНИХ ПІДПИСОК" FontWeight="Bold" Foreground="{DynamicResource Yellow}"/>
                                    <TextBlock Text="ID каналів монетизації" Foreground="{DynamicResource Muted}" Margin="0,7,0,0"/>
                                    <TextBox x:Name="MonetizationChannelIdsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="48" Margin="0,4,0,0"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Згадування" Foreground="{DynamicResource Muted}"/><TextBox x:Name="MonetizationMentionBox" Margin="0,4,0,0"/></StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <CheckBox x:Name="MonetizationEnabledCheck" Content="Увімкнути окремі сповіщення монетизації"/>
                                            <WrapPanel Margin="0,5,0,0">
                                                <CheckBox x:Name="DonatelloMoneyCheck" Content="Donatello"/>
                                                <CheckBox x:Name="TwitchMoneyCheck" Content="Twitch Bits / Subs" Margin="14,3,3,3"/>
                                                <CheckBox x:Name="YouTubeMoneyCheck" Content="YouTube Super Chat / Members" Margin="14,3,3,3"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="ЗБЕРЕГТИ" Click="Save_Click" Background="{DynamicResource Purple}" ui:CyberUi.IconGlyph="&#xE74E;"/>
                                <Button Content="СТВОРИТИ БОТА" Click="OpenDiscordPortal_Click" ui:CyberUi.IconGlyph="&#xE710;"/>
                                <Button Content="ДОДАТИ НА СЕРВЕР" Click="OpenDiscordInvite_Click" ui:CyberUi.IconGlyph="&#xE716;"/>
                                <Button Content="ВІДКРИТИ КАНАЛИ" Click="OpenChannels_Click" ui:CyberUi.IconGlyph="&#xE716;"/>
                                <Button Content="ЗАБУТИ TOKEN" Click="ForgetToken_Click" Background="{DynamicResource DangerBg}" ui:CyberUi.IconGlyph="&#xE74D;"/>
                            </WrapPanel>
                            <TextBlock Text="Bot Token зберігається у Windows Credential Manager. Канали трансляцій і монетизації працюють незалежно." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Column="1" Width="7" Background="{DynamicResource Line}" ShowsPreview="True"/>

                <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="90"/><RowDefinition Height="110"/><RowDefinition Height="Auto"/><RowDefinition Height="34"/><RowDefinition/></Grid.RowDefinitions>
                        <Border Background="{DynamicResource SuccessBg}" BorderBrush="{DynamicResource Green}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="СТАН ЛОКАЛЬНОГО БОТА" Foreground="{DynamicResource Muted}" FontWeight="Bold"/><TextBlock x:Name="BotStatusText" Text="ЗУПИНЕНО" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Yellow}" Margin="0,4,0,0"/></StackPanel>
                                <Ellipse Grid.Column="1" x:Name="BotStatusDot" Width="26" Height="26" Fill="{DynamicResource Yellow}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                            <Button Content="ЗАПУСТИТИ БОТА" Click="StartBot_Click" Background="{DynamicResource SuccessBg}" ui:CyberUi.IconGlyph="&#xE768;"/>
                            <Button Content="ЗУПИНИТИ" Click="StopBot_Click" Background="{DynamicResource DangerBg}" ui:CyberUi.IconGlyph="&#xE71A;"/>
                            <Button Content="ПЕРЕВІРИТИ ЗАРАЗ" Click="CheckNow_Click" Background="{DynamicResource Blue}" ui:CyberUi.IconGlyph="&#xE73E;"/>
                            <Button Content="ТЕСТ КАНАЛУ СТРІМІВ" Click="TestDiscord_Click" Background="{DynamicResource Purple}" ui:CyberUi.IconGlyph="&#xE7BA;"/>
                            <Button Content="ТЕСТ КАНАЛУ ДОНАТІВ" Click="TestMonetization_Click" Background="{DynamicResource AccentSoft}" ui:CyberUi.IconGlyph="&#xE7BA;"/>
                        </WrapPanel>
                        <Border Grid.Row="2" Background="{DynamicResource PanelDark}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,6,0,8">
                            <StackPanel><TextBlock x:Name="ConfigurationStateText" Text="Заповніть Discord Bot Token та ID каналів." TextWrapping="Wrap"/><TextBlock x:Name="LastActionText" Text="Готово до налаштування." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel>
                        </Border>
                        <TextBlock Grid.Row="3" Text="ЖУРНАЛ БОТА" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                        <ItemsControl Grid.Row="4" x:Name="BotLogList" Margin="0,5,0,0">
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource ListSeparator}" BorderThickness="0,0,0,1" Padding="7,5"><TextBlock Text="{Binding}" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10">
                <Grid><TextBlock Text="TiHiY Stream Notify Bot: окремий канал стартів + окремий канал донатів і підписок." Foreground="{DynamicResource Green}" VerticalAlignment="Center"/><Button Content="ЗАКРИТИ" ui:CyberUi.IconGlyph="&#xE8BB;" HorizontalAlignment="Right" Click="Close_Click"/></Grid>
            </Border>
        </Grid>
        </Grid>
    </Border>
</services:ModuleWindowBase>
