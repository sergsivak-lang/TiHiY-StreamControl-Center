<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="TiHiY StreamControl Center — Налаштування"
        Width="1280" Height="800" MinWidth="920" MinHeight="620"
        WindowStyle="None" ResizeMode="CanResize">
    <services:ModuleWindowBase.Resources>
        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource Text}"/>
            <Setter Property="Background" Value="{DynamicResource Panel2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="MinWidth" Value="215"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Amber}"/><Setter TargetName="Root" Property="Background" Value="#14355A"/><Setter Property="Foreground" Value="{DynamicResource Amber}"/></Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Cyan}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Amber}"/><Setter Property="FontSize" Value="18"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Margin" Value="0,0,0,10"/></Style>
        <Style x:Key="SettingsCard" TargetType="Border"><Setter Property="Background" Value="{DynamicResource PanelGradient}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="7"/><Setter Property="Padding" Value="14"/><Setter Property="Margin" Value="0,0,0,10"/></Style>
    </services:ModuleWindowBase.Resources>

    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
        <Grid x:Name="DesignSurface" Margin="10">
            <Grid.RowDefinitions><RowDefinition Height="82"/><RowDefinition Height="*"/><RowDefinition Height="54"/></Grid.RowDefinitions>
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/header-emblem.png" Width="100" Height="110" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-4,-8,0,0"/>
                <StackPanel Margin="104,9,0,0"><StackPanel Orientation="Horizontal"><TextBlock Text="TiHiY" FontSize="30" FontWeight="Black"/><TextBlock Text="  StreamControl Center" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource Amber}"/></StackPanel><TextBlock Text="НАЛАШТУВАННЯ  •  SETTINGS" Foreground="{DynamicResource Cyan}" FontWeight="SemiBold" Margin="2,3,0,0"/></StackPanel>
                <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/header-wheat.png" Width="150" Height="72" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,7,0,0"><Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/><Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/><Button Style="{StaticResource DangerButton}" Content="×" Click="Close_Click"/></StackPanel>
            </Grid>

            <TabControl Grid.Row="1" TabStripPlacement="Left" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource SettingsTabItem}">
                <TabItem Header="⚙  Загальні / General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="16,0,0,0">
                        <TextBlock Text="ЗАГАЛЬНІ / GENERAL" Style="{StaticResource SettingsSectionTitle}"/>
                        <Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Масштаб і поведінка інтерфейсу" FontWeight="Bold" FontSize="15"/><WrapPanel Margin="0,10,0,0"><CheckBox x:Name="AutoScaleCheck" Content="Автоматичний масштаб" Checked="AutoScaleCheck_Changed" Unchecked="AutoScaleCheck_Changed"/><TextBlock Text="Ручний масштаб:" VerticalAlignment="Center" Margin="18,0,6,0"/><Button Content="−" Width="40" Click="ScaleDown_Click"/><TextBlock x:Name="ScaleText" Text="100%" Width="64" TextAlignment="Center" VerticalAlignment="Center"/><Button Content="+" Width="40" Click="ScaleUp_Click"/></WrapPanel><WrapPanel Margin="0,10,0,0"><Button Content="ВІДНОВИТИ СТАНДАРТНИЙ МАКЕТ" Click="ResetDashboardLayout_Click"/><Button Content="ВІДКРИТИ ПАПКУ НАЛАШТУВАНЬ" Click="OpenSettingsFolder_Click"/></WrapPanel></StackPanel></Border>
                        <Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Мова програми / Application language" FontWeight="Bold" FontSize="15"/><TextBlock Text="Підтримувані мови: Українська та English. Повне перемикання всіх вікон буде доступне через єдиний словник локалізації." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel></Border>
                    </StackPanel></ScrollViewer>
                </TabItem>

                <TabItem Header="🎨  Тема та інтерфейс">
                    <Grid Margin="16,0,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="0.42*"/><ColumnDefinition Width="0.58*"/></Grid.ColumnDefinitions>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="0,0,12,0"><TextBlock Text="ТЕМА ТА ІНТЕРФЕЙС / THEME &amp; UI" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Вибір теми" FontWeight="Bold"/><ComboBox x:Name="ThemeCombo" SelectionChanged="ThemeCombo_SelectionChanged" MinHeight="38" Margin="0,8,0,0"/><TextBlock Text="Наведіть курсор або виберіть тему, щоб побачити її зразок праворуч." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/><WrapPanel Margin="0,12,0,0"><Button Content="ЗАСТОСУВАТИ ТЕМУ" Click="ApplyTheme_Click" Style="{StaticResource AmberButton}"/><Button Content="ВІДНОВИТИ DEFAULT" Click="RestoreDefaultTheme_Click"/></WrapPanel></StackPanel></Border><Border Style="{StaticResource SettingsCard}"><StackPanel><CheckBox Content="Анімації інтерфейсу" IsChecked="True"/><CheckBox Content="Показувати підказки" IsChecked="True"/><CheckBox Content="Блокувати макет після запуску" IsChecked="True"/></StackPanel></Border></StackPanel></ScrollViewer>
                        <Border x:Name="ThemePreviewBorder" Grid.Column="1" Background="{DynamicResource PanelGradient}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="8" ClipToBounds="True"><Grid><Image x:Name="ThemePreviewImage" Stretch="UniformToFill" Opacity="0.88"/><Border Background="#B0051324" VerticalAlignment="Bottom" Margin="8" CornerRadius="6" Padding="14"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="ThemePreviewName" Text="Україна" Foreground="{DynamicResource Amber}" FontWeight="Bold" FontSize="19"/><TextBlock x:Name="ThemePreviewDescription" Text="Попередній перегляд теми" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,5,10,0"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Ellipse x:Name="ThemePreviewPrimary" Width="26" Height="26" Fill="{DynamicResource Cyan}" Margin="3"/><Ellipse x:Name="ThemePreviewAccent" Width="26" Height="26" Fill="{DynamicResource Amber}" Margin="3"/><Ellipse x:Name="ThemePreviewSuccess" Width="26" Height="26" Fill="{DynamicResource Green}" Margin="3"/></StackPanel></Grid></Border></Grid></Border>
                    </Grid>
                </TabItem>

                <TabItem Header="📡  Трансляція / Broadcast"><StackPanel Margin="16,0,0,0"><TextBlock Text="ТРАНСЛЯЦІЯ / BROADCAST" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Оперативне керування трансляцією" FontWeight="Bold" FontSize="15"/><TextBlock Text="Налаштування YouTube-трансляції, каналів і overlay зібрані в цьому розділі." Foreground="{DynamicResource Muted}" Margin="0,6,0,10"/><WrapPanel><Button Content="YOUTUBE STREAM SETTINGS" Click="OpenYouTubeSettingsWindow_Click"/><Button Content="КАНАЛИ ТА ОБЛІКОВІ ЗАПИСИ" Click="OpenChannelsWindow_Click"/><Button Content="OVERLAY OBS" Click="OpenOverlayWindow_Click"/><Button Content="YOUTUBE STUDIO" Click="OpenBroadcastDashboard_Click"/></WrapPanel></StackPanel></Border></StackPanel></TabItem>

                <TabItem Header="◉  OBS"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="16,0,0,0"><TextBlock Text="OBS WEBSOCKET" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel Margin="0,0,6,0"><TextBlock Text="Адреса OBS WebSocket" Foreground="{DynamicResource Muted}"/><TextBox x:Name="ObsUrlBox" Text="ws://127.0.0.1:4455" Margin="0,4,0,0"/></StackPanel><StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Пароль" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="ObsPasswordBox" Margin="0,4,0,0"/></StackPanel></Grid><WrapPanel Margin="0,8,0,0"><CheckBox x:Name="RememberPasswordCheck" Content="Запам’ятати пароль"/><CheckBox x:Name="AutoConnectCheck" Content="Підключатися автоматично" Margin="12,3,3,3"/></WrapPanel><WrapPanel Margin="0,8,0,0"><Button Content="ЗБЕРЕГТИ Й ПІДКЛЮЧИТИ" Click="SaveAndConnect_Click" Background="#1453A5"/><Button Content="ВІДКЛЮЧИТИ OBS" Click="Disconnect_Click"/><Button Content="ЗАБУТИ ПАРОЛЬ" Click="ForgetPassword_Click" Background="#7C2027"/></WrapPanel><TextBlock x:Name="ObsStatusText" Text="OBS не підключено" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="4,8,0,0"/></StackPanel></Border></StackPanel></ScrollViewer></TabItem>

                <TabItem Header="T  Twitch"><StackPanel Margin="16,0,0,0"><TextBlock Text="TWITCH" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Авторизація, чат, модерація та автопідключення Twitch." TextWrapping="Wrap"/><Button Content="ВІДКРИТИ КАНАЛИ ТА TWITCH" Click="OpenChannelsWindow_Click" HorizontalAlignment="Left" Margin="0,12,0,0"/></StackPanel></Border></StackPanel></TabItem>
                <TabItem Header="▶  YouTube"><StackPanel Margin="16,0,0,0"><TextBlock Text="YOUTUBE" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="OAuth, канал, активна трансляція, live chat і статистика лайків." TextWrapping="Wrap"/><WrapPanel Margin="0,12,0,0"><Button Content="НАЛАШТУВАННЯ YOUTUBE" Click="OpenYouTubeSettingsWindow_Click"/><Button Content="ВІДКРИТИ YOUTUBE STUDIO" Click="OpenBroadcastDashboard_Click"/></WrapPanel></StackPanel></Border></StackPanel></TabItem>
                <TabItem Header="D  Discord"><StackPanel Margin="16,0,0,0"><TextBlock Text="DISCORD" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Discord-бот, сервер, канали та сповіщення."/><Button Content="ВІДКРИТИ DISCORD СПОВІЩЕННЯ" Click="OpenNotificationsWindow_Click" HorizontalAlignment="Left" Margin="0,12,0,0"/></StackPanel></Border></StackPanel></TabItem>
                <TabItem Header="♥  Донати / Donations"><StackPanel Margin="16,0,0,0"><TextBlock Text="ДОНАТИ / DONATIONS" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Donatello, токени, віджети, звуки та правила показу донатів." TextWrapping="Wrap"/><Button Content="ВІДКРИТИ DONATELLO" Click="OpenDonatelloWindow_Click" HorizontalAlignment="Left" Margin="0,12,0,0"/></StackPanel></Border></StackPanel></TabItem>
                <TabItem Header="♫  Музика / Music"><StackPanel Margin="16,0,0,0"><TextBlock Text="МУЗИКА / MUSIC" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Плейлист, локальні файли, Now Playing і відтворення."/><Button Content="ВІДКРИТИ МУЗИЧНИЙ ПЛЕЄР" Click="OpenMusicWindow_Click" HorizontalAlignment="Left" Margin="0,12,0,0"/></StackPanel></Border></StackPanel></TabItem>
                <TabItem Header="🛡  Безпека / Security"><StackPanel Margin="16,0,0,0"><TextBlock Text="БЕЗПЕКА / SECURITY" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="Паролі та ключі зберігаються окремо від settings.json. OBS-пароль використовує Windows Credential Manager." TextWrapping="Wrap"/><Button Content="ВИДАЛИТИ ЗБЕРЕЖЕНИЙ OBS-ПАРОЛЬ" Click="ForgetPassword_Click" HorizontalAlignment="Left" Margin="0,12,0,0"/></StackPanel></Border></StackPanel></TabItem>

                <TabItem Header="▤  Журнал / Logs"><Grid Margin="16,0,0,0"><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition/><RowDefinition Height="50"/></Grid.RowDefinitions><Grid><TextBlock Text="ЖУРНАЛ ПОДІЙ" Style="{StaticResource SettingsSectionTitle}"/><TextBlock Text="Останні 14 записів" HorizontalAlignment="Right" Foreground="{DynamicResource Muted}"/></Grid><ItemsControl Grid.Row="1" ItemsSource="{Binding VisibleLogs}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="14" Columns="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="7,4"><TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Muted}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="ОЧИСТИТИ" Click="ClearLog_Click"/><Button Content="ВІДКРИТИ ПАПКУ LOGS" Click="OpenLogs_Click" Background="#123B32"/></StackPanel></Grid></TabItem>
                <TabItem Header="ⓘ  Про програму / About"><StackPanel Margin="16,0,0,0"><TextBlock Text="ПРО ПРОГРАМУ / ABOUT" Style="{StaticResource SettingsSectionTitle}"/><Border Style="{StaticResource SettingsCard}"><StackPanel><TextBlock Text="TiHiY StreamControl Center" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Amber}"/><TextBlock Text="Версія 1.0.5.3 • .NET 9 • Windows x64" Margin="0,7,0,0"/><TextBlock Text="Єдиний центр керування мультичатом, донатами, OBS Audio, музикою та сповіщеннями." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel></Border></StackPanel></TabItem>
            </TabControl>

            <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="9" Margin="0,8,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Text="Налаштування готові" Foreground="{DynamicResource Green}" VerticalAlignment="Center"/><Button Grid.Column="1" Content="ЗАКРИТИ" Click="Close_Click"/></Grid></Border>
        </Grid>
    </Border>
</services:ModuleWindowBase>