<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="Налаштування та журнал" Icon="/TiHiY.StreamControlCenter;component/Assets/TiHiY.StreamControlCenter.ico" Width="1160" Height="760" MinWidth="880" MinHeight="580" WindowStyle="None" ResizeMode="CanResize">
    <Border BorderBrush="{DynamicResource CyanSoft}" BorderThickness="1" Background="{StaticResource Bg0}">
            <Grid x:Name="DesignSurface" Margin="12">
                <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition/><RowDefinition Height="58"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="SYSTEM SETTINGS" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Cyan}"/><TextBlock Text="  •  OBS PASSWORD + SCALE + LOG" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Style="{StaticResource TitleButton}" Content="—" Width="40" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="Minimize_Click"/><Button Style="{StaticResource TitleButton}" Content="□" Width="40" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="Maximize_Click"/><Button Style="{StaticResource CloseTitleButton}" Content="×" Width="40" Height="32" Padding="0" Background="{DynamicResource RedButtonBackground}" BorderThickness="0" Click="Close_Click"/></StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="1" Margin="0,12,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.25*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="76"/><RowDefinition Height="76"/><RowDefinition Height="58"/><RowDefinition Height="120"/><RowDefinition/></Grid.RowDefinitions>
                            <TextBlock Text="OBS WEBSOCKET" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Cyan}"/>
                            <StackPanel Grid.Row="1"><TextBlock Text="Адреса OBS WebSocket" Foreground="{StaticResource Muted}"/><TextBox x:Name="ObsUrlBox" Text="ws://127.0.0.1:4455" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="2"><TextBlock Text="Пароль" Foreground="{StaticResource Muted}"/><PasswordBox x:Name="ObsPasswordBox" Margin="0,5,0,0"/></StackPanel>
                            <WrapPanel Grid.Row="3"><CheckBox x:Name="RememberPasswordCheck" Content="Запам’ятати пароль у Windows Credential Manager"/><CheckBox x:Name="AutoConnectCheck" Content="Підключатися автоматично"/></WrapPanel>
                            <StackPanel Grid.Row="4"><WrapPanel><Button Content="ЗБЕРЕГТИ Й ПІДКЛЮЧИТИ" Click="SaveAndConnect_Click" Background="{DynamicResource BlueButtonBackground}"/><Button Content="ВІДКЛЮЧИТИ OBS" Click="Disconnect_Click"/><Button Content="ЗАБУТИ ПАРОЛЬ" Click="ForgetPassword_Click" Background="{DynamicResource RedButtonBackground}"/></WrapPanel><TextBlock x:Name="ObsStatusText" Text="OBS не підключено" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="4,8,0,0"/></StackPanel>
                            <StackPanel Grid.Row="5"><TextBlock Text="ІНТЕРФЕЙС" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Cyan}" Margin="0,5,0,10"/><WrapPanel><CheckBox x:Name="AutoScaleCheck" Content="Автоматичний масштаб" Checked="AutoScaleCheck_Changed" Unchecked="AutoScaleCheck_Changed"/><TextBlock Text="Ручний масштаб:" VerticalAlignment="Center" Margin="15,0,5,0"/><Button Content="−" Width="40" Click="ScaleDown_Click"/><TextBlock x:Name="ScaleText" Text="100%" Width="58" TextAlignment="Center" VerticalAlignment="Center"/><Button Content="+" Width="40" Click="ScaleUp_Click"/></WrapPanel><TextBlock Text="Діапазон 75–150%. Налаштування діє на головне та всі модульні вікна." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="3,8,0,0"/></StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,0,0,0">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition/><RowDefinition Height="50"/></Grid.RowDefinitions>
                            <Grid><TextBlock Text="ЖУРНАЛ ПОДІЙ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Cyan}"/><TextBlock Text="Останні 14 записів" HorizontalAlignment="Right" Foreground="{StaticResource Muted}"/></Grid>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding VisibleLogs}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="14" Columns="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="7,4"><TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" Foreground="{StaticResource Muted}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="ОЧИСТИТИ" Click="ClearLog_Click"/><Button Content="ВІДКРИТИ ПАПКУ LOGS" Click="OpenLogs_Click" Background="#0A3225"/></StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                <Border Grid.Row="2" Background="{DynamicResource PanelDeep}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Padding="9">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Text="Пароль не зберігається у settings.json або GitHub" Foreground="{StaticResource Green}" VerticalAlignment="Center"/><Button Grid.Column="1" Content="ВІДКРИТИ ПАПКУ НАЛАШТУВАНЬ" Click="OpenSettingsFolder_Click"/></Grid>
                </Border>
            </Grid>
    </Border>
</services:ModuleWindowBase>
