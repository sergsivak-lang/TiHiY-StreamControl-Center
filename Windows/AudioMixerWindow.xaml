<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.AudioMixerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        xmlns:ui="clr-namespace:TiHiY.StreamControlCenter.Services"
        xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
        Title="Аудіомікшер OBS" Width="1320" Height="820" MinWidth="940" MinHeight="620" WindowStyle="None" ResizeMode="CanResize">
    <Border Style="{StaticResource AppWindowFrame}">
        <Grid Background="{DynamicResource AppBackgroundBrush}">
            <Rectangle Fill="{DynamicResource CircuitBackdropBrush}" IsHitTestVisible="False"/>
            <Grid x:Name="DesignSurface" Margin="9">
                <Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="64"/><RowDefinition/><RowDefinition Height="68"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource TitleBarBorder}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Accent}" BorderThickness="1"><TextBlock Text="&#xE9E9;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Accent}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Margin="11,0,0,0"><TextBlock Text="ПОВНИЙ АУДІОМІКШЕР / AUDIO MIXER OBS" Style="{StaticResource SectionTitle}" FontSize="22"/><TextBlock Text="Двостороння синхронізація гучності, MUTE та рівнів із OBS" Foreground="{DynamicResource Muted}"/></StackPanel></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Button Content="&#xE921;" Click="Minimize_Click" Style="{StaticResource WindowControlButton}"/><Button Content="&#xE922;" Click="Maximize_Click" Style="{StaticResource WindowControlButton}"/><Button Content="&#xE8BB;" Click="Close_Click" Style="{StaticResource WindowControlButton}" Background="{DynamicResource CloseBg}" BorderBrush="{DynamicResource Red}"/></StackPanel>
                    </Grid>
                </Border>

                <ContentControl Grid.Row="1" Style="{StaticResource CyberPanel}" Padding="9" Margin="0,8,0,4">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock Text="ДЖЕРЕЛА AUDIO MIXER OBS" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><TextBlock Text="Показуються реальні аудіовходи OBS. Browser Source без аудіовиходу автоматично виключаються." Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button x:Name="ShowAllButton" Content="ПОКАЗАТИ ВСІ ДЛЯ ВИБОРУ" Click="ToggleShowAll_Click" ui:CyberUi.IconGlyph="&#xE890;"/><Button Content="ОНОВИТИ КАНАЛИ" Click="Refresh_Click" Style="{StaticResource AccentButton}" ui:CyberUi.IconGlyph="&#xE72C;"/></StackPanel></Grid>
                </ContentControl>

                <ContentControl Grid.Row="2" Style="{StaticResource CyberPanel}" Margin="0,4,0,4">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition/><RowDefinition Height="48"/></Grid.RowDefinitions>
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="8,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="210"/><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="88"/><ColumnDefinition Width="82"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions><TextBlock Text="#" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="КАНАЛ / ДЖЕРЕЛО" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="РІВЕНЬ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="ГУЧНІСТЬ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="ДБ" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><TextBlock Grid.Column="5" Text="MUTE" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/><TextBlock Grid.Column="6" Text="ШВИДКИЙ МІКШЕР" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/></Grid>
                        </Border>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ChannelPage}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="1" Rows="6"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:AudioChannel}">
                                <Border Background="{DynamicResource PanelDark}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,0.65" Padding="8,5">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="210"/><ColumnDefinition Width="180"/><ColumnDefinition/><ColumnDefinition Width="88"/><ColumnDefinition Width="82"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions>
                                        <Border Width="34" Height="34" CornerRadius="4" BorderBrush="{DynamicResource Accent}" BorderThickness="1" Background="{DynamicResource InputBg}" VerticalAlignment="Center"><TextBlock Text="{Binding IconGlyph}" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Accent}" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Kind}" Foreground="{DynamicResource Muted}" FontSize="10" TextTrimming="CharacterEllipsis"/></StackPanel>
                                        <ProgressBar Grid.Column="2" Value="{Binding Meter}" Maximum="1" Height="11" Margin="5,0,15,0" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="3" Value="{Binding Volume}" Minimum="0" Maximum="1" Tag="{Binding}" ValueChanged="VolumeSlider_ValueChanged" Margin="5,0,18,0"/>
                                        <TextBlock Grid.Column="4" Text="{Binding DbText}" Foreground="{DynamicResource Accent}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <Button Grid.Column="5" Content="" ui:CyberUi.IconGlyph="&#xE74F;" Tag="{Binding}" Click="Mute_Click" Background="#52212A" BorderBrush="{DynamicResource Red}" Padding="2" Margin="10,2" ToolTip="{Binding MuteText}"/>
                                        <Button Grid.Column="6" Content="{Binding PinText}" ui:CyberUi.IconGlyph="&#xE718;" Tag="{Binding}" Click="Pin_Click" Background="{DynamicResource SuccessBg}" BorderBrush="{DynamicResource Green}" FontSize="10" Padding="4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Grid.Row="2" Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions><Button Grid.Column="1" Content="‹" Width="46" Click="PreviousPage_Click"/><TextBlock x:Name="PageText" Grid.Column="2" Text="1 / 1" VerticalAlignment="Center" Margin="14,0"/><Button Grid.Column="3" Content="›" Width="46" Click="NextPage_Click"/></Grid>
                    </Grid>
                </ContentControl>

                <ContentControl Grid.Row="3" Style="{StaticResource CyberPanel}" Padding="9" Margin="0,4,0,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Width="36" Height="36" CornerRadius="4" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource Green}" BorderThickness="1"><TextBlock Text="&#xE946;" FontFamily="{StaticResource IconFont}" Foreground="{DynamicResource Green}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Grid.Column="1" x:Name="StatusText" Text="OBS не підключено" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" TextWrapping="Wrap"/><StackPanel Grid.Column="2" Orientation="Horizontal"><Button Content="MUTE ALL" Click="MuteAll_Click" Background="{DynamicResource DangerBg}" BorderBrush="{DynamicResource Red}" ui:CyberUi.IconGlyph="&#xE74F;"/><Button Content="UNMUTE ALL" Click="UnmuteAll_Click" Background="{DynamicResource SuccessBg}" BorderBrush="{DynamicResource Green}" ui:CyberUi.IconGlyph="&#xE74F;"/></StackPanel></Grid>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</services:ModuleWindowBase>
