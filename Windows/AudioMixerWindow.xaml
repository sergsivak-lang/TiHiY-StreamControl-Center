<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.AudioMixerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
        Title="Аудіомікшер OBS" Width="1220" Height="790" MinWidth="900" MinHeight="600" WindowStyle="None" ResizeMode="CanResize">
    <Border BorderBrush="#2B829A" BorderThickness="1" Background="{StaticResource WindowGradient}">
            <Grid x:Name="DesignSurface" Margin="12">
                <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition Height="64"/><RowDefinition/><RowDefinition Height="54"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#061822" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="AUDIO MIXER OBS" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Cyan}"/><TextBlock Text="  •  ЛИШЕ КАНАЛИ З МІКШЕРА OBS" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="—" Width="40" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="Minimize_Click"/><Button Content="□" Width="40" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="Maximize_Click"/><Button Content="×" Width="40" Height="32" Padding="0" Background="#3B0D13" BorderBrush="{StaticResource Red}" BorderThickness="0" Click="Close_Click"/></StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="#06131C" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="12,8">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center"><TextBlock Text="Джерело списку: Audio Mixer OBS" FontWeight="Bold"/><TextBlock Text="Зображення, текст і Browser Source без аудіовиходу автоматично виключаються." Foreground="{StaticResource Muted}"/></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"><Button x:Name="ShowAllButton" Content="ПОКАЗАТИ ВСІ ДЛЯ ВИБОРУ" Click="ToggleShowAll_Click"/><Button Content="ОНОВИТИ КАНАЛИ" Click="Refresh_Click" Background="#1453A5" VerticalAlignment="Center"/></StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,12,0,8">
                    <Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="44"/></Grid.RowDefinitions>
                        <ItemsControl ItemsSource="{Binding ChannelPage}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" Rows="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:AudioChannel}">
                                <Border Background="#071923" BorderBrush="#255767" BorderThickness="1" CornerRadius="6" Margin="7" Padding="12">
                                    <Grid><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="40"/><RowDefinition Height="58"/><RowDefinition Height="44"/><RowDefinition Height="44"/></Grid.RowDefinitions>
                                        <Grid><TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding DbText}" HorizontalAlignment="Right" Foreground="{StaticResource Muted}"/></Grid>
                                        <ProgressBar Grid.Row="1" Value="{Binding Meter}" Maximum="1" Height="16" VerticalAlignment="Center"/>
                                        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="VOL" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/><Slider Grid.Column="1" Value="{Binding Volume}" Minimum="0" Maximum="1" Tag="{Binding}" ValueChanged="VolumeSlider_ValueChanged"/></Grid>
                                        <Button Grid.Row="3" Content="{Binding MuteText}" Tag="{Binding}" Click="Mute_Click" Background="#52212A" HorizontalAlignment="Center" MinWidth="110"/><Button Grid.Row="4" Content="{Binding PinText}" Tag="{Binding}" Click="Pin_Click" Background="#123B32" HorizontalAlignment="Center" MinWidth="140"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Button Grid.Column="1" Content="‹" Width="46" Click="PreviousPage_Click"/><TextBlock x:Name="PageText" Grid.Column="2" Text="1 / 1" VerticalAlignment="Center" Margin="14,0"/><Button Grid.Column="3" Content="›" Width="46" Click="NextPage_Click"/>
                        </Grid>
                    </Grid>
                </Border>
                <Border Grid.Row="3" Background="#06131C" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Padding="8">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Text="OBS не підключено" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="MUTE ALL" Click="MuteAll_Click" Background="#7C2027"/><Button Content="UNMUTE ALL" Click="UnmuteAll_Click" Background="#123B32"/></StackPanel></Grid>
                </Border>
            </Grid>
    </Border>
</services:ModuleWindowBase>
